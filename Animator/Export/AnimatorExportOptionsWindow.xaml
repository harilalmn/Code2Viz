<Window x:Class="Animator.Export.AnimatorExportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Animation"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SecondaryBackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource ForegroundBrush}"
                   Margin="0,0,0,16"
                   Text="Export Animation"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Duration (s)" VerticalAlignment="Center"
                       Foreground="{StaticResource ForegroundBrush}"/>
            <Slider Grid.Column="1"
                    x:Name="SliderDuration"
                    Minimum="1" Maximum="60" Value="5"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                       x:Name="TextDuration"
                       Text="5"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource ForegroundBrush}"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Frame rate" VerticalAlignment="Center"
                       Foreground="{StaticResource ForegroundBrush}"/>
            <Slider Grid.Column="1"
                    x:Name="SliderFps"
                    Minimum="5" Maximum="60" Value="30"
                    TickFrequency="5" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                       x:Name="TextFps"
                       Text="30"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource ForegroundBrush}"/>
        </Grid>

        <TextBlock Grid.Row="3"
                   x:Name="TextFrameInfo"
                   Foreground="{StaticResource MutedForegroundBrush}"
                   Margin="0,0,0,16"
                   Text="Total frames: 150"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    IsCancel="True"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Padding="14,5"/>
            <Button Content="Export"
                    IsDefault="True"
                    Click="Export_Click"
                    Style="{StaticResource RunButtonStyle}"
                    Margin="8,0,0,0"
                    Padding="14,5"/>
        </StackPanel>
    </Grid>
</Window>
