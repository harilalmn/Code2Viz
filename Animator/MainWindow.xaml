<Window x:Class="Animator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c2a="clr-namespace:Animator.Canvas"
        xmlns:console="clr-namespace:Animator.Console"
        xmlns:minimap="clr-namespace:Code2Viz.Editor.Minimap"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Animator"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Colored row template for the console -->
        <DataTemplate DataType="{x:Type console:ConsoleLine}">
            <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                <Setter Property="Foreground" Value="#DCDCAA"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                <Setter Property="Foreground" Value="#F44747"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsClickable}" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="ToolTip" Value="Double-click to go to this line"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>                              <!-- menu bar -->
            <RowDefinition Height="Auto"/>                              <!-- toolbar -->
            <RowDefinition Height="*"/>                                 <!-- editor | canvas -->
            <RowDefinition x:Name="ConsoleSplitterRow" Height="Auto"/>  <!-- splitter -->
            <RowDefinition x:Name="ConsoleRow"         Height="180"/>   <!-- console -->
        </Grid.RowDefinitions>

        <!--  Header: branding strip + menu bar (Code2Viz-style ribbon)  -->
        <StackPanel Grid.Row="0" Orientation="Vertical">

            <!--  Branding strip  -->
            <Border Background="{StaticResource SecondaryBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="40" Height="40" Source="/img/logo.png"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel Orientation="Vertical" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Animator" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource ForegroundBrush}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Doodle in dotnet." FontFamily="Segoe UI" FontSize="13"
                                       FontStyle="Italic" FontWeight="SemiBold" Margin="0,0,8,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0.0" Color="{StaticResource AccentColor}"/>
                                        <GradientStop Offset="1.0" Color="{StaticResource SuccessColor}"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock x:Name="VersionText" Text="v0.0.0" FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedForegroundBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Menu Bar  -->
            <Border Background="{StaticResource SecondaryBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Menu Background="Transparent">
                <Menu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="8,6"/>
                    </Style>
                    <Style x:Key="MenuItemStyle" TargetType="MenuItem">
                        <Setter Property="Foreground" Value="#1E1E1E"/>
                        <Setter Property="Padding" Value="8,4"/>
                    </Style>
                </Menu.Resources>

                <MenuItem Header="_File">
                    <MenuItem Header="_New"        Click="NewButton_Click"     InputGestureText="Ctrl+N" Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem Header="_Open..."    Click="OpenButton_Click"    InputGestureText="Ctrl+O" Style="{StaticResource MenuItemStyle}"/>
                    <Separator/>
                    <MenuItem Header="_Save"       Click="SaveButton_Click"    InputGestureText="Ctrl+S" Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem Header="Save _As..." Click="SaveAsMenuItem_Click"                          Style="{StaticResource MenuItemStyle}"/>
                    <Separator/>
                    <MenuItem Header="Export _GIF Animation..."  Click="ExportGifMenuItem_Click"   Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem Header="Export _Video (MP4)..."    Click="ExportMp4MenuItem_Click"   Style="{StaticResource MenuItemStyle}"/>
                    <Separator/>
                    <MenuItem Header="Switch to _Project" Click="SwitchToCode2Viz_Click" Style="{StaticResource MenuItemStyle}"/>
                    <Separator/>
                    <MenuItem Header="E_xit" Click="ExitMenuItem_Click" InputGestureText="Alt+F4" Style="{StaticResource MenuItemStyle}"/>
                </MenuItem>

                <MenuItem Header="_View">
                    <MenuItem x:Name="InlayHintsMenuItem"
                              Header="_Inlay Hints"
                              Click="InlayHintsMenuItem_Click"
                              IsCheckable="True"
                              IsChecked="False"
                              Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem x:Name="SemanticHighlightingMenuItem"
                              Header="_Semantic Highlighting"
                              Click="SemanticHighlightingMenuItem_Click"
                              IsCheckable="True"
                              IsChecked="True"
                              Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem x:Name="CodeLensMenuItem"
                              Header="Code _Lens"
                              Click="CodeLensMenuItem_Click"
                              IsCheckable="True"
                              IsChecked="True"
                              Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem x:Name="MinimapMenuItem"
                              Header="_Minimap"
                              Click="MinimapMenuItem_Click"
                              IsCheckable="True"
                              IsChecked="True"
                              Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem x:Name="ConsoleMenuItem"
                              Header="Show C_onsole"
                              Click="ConsoleMenuItem_Click"
                              IsCheckable="True"
                              IsChecked="True"
                              Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem x:Name="CanvasBorderMenuItem"
                              Header="Canvas _Border"
                              Click="CanvasBorderMenuItem_Click"
                              IsCheckable="True"
                              IsChecked="True"
                              Style="{StaticResource MenuItemStyle}"/>
                    <Separator/>
                    <MenuItem Header="Clear Co_nsole" Click="ClearConsoleButton_Click" Style="{StaticResource MenuItemStyle}"/>
                </MenuItem>

                <MenuItem Header="_Run">
                    <MenuItem Header="_Run Sketch" Click="RunButton_Click"  InputGestureText="F5"       Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem Header="_Stop"       Click="StopButton_Click" InputGestureText="Shift+F5" Style="{StaticResource MenuItemStyle}"/>
                </MenuItem>

                <MenuItem Header="_Help">
                    <MenuItem Header="_Help"           Click="HelpMenuItem_Click"  InputGestureText="F1" Style="{StaticResource MenuItemStyle}"/>
                    <Separator/>
                    <MenuItem Header="_About Animator" Click="AboutMenuItem_Click"                       Style="{StaticResource MenuItemStyle}"/>
                </MenuItem>
                </Menu>
            </Border>
        </StackPanel>

        <!--  Toolbar  -->
        <Border Grid.Row="1"
                Background="{StaticResource SecondaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- file label + file buttons -->
                    <ColumnDefinition Width="*"/>     <!-- spacer -->
                    <ColumnDefinition Width="Auto"/>  <!-- run/stop -->
                    <ColumnDefinition Width="Auto"/>  <!-- switch app -->
                </Grid.ColumnDefinitions>

                <!--  Left side: file ops + status  -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="New" Click="NewButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Ctrl+N"/>
                    <Button Content="Open…" Click="OpenButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Ctrl+O"/>
                    <Button Content="Save" Click="SaveButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Ctrl+S"/>
                    <TextBlock x:Name="FileLabel"
                               Text="Untitled.cs"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"
                               Foreground="{StaticResource MutedForegroundBrush}"/>
                </StackPanel>

                <!--  Centre: status  -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusLabel"
                               Text="Ready"
                               Foreground="{StaticResource MutedForegroundBrush}"/>
                    <TextBlock x:Name="FrameLabel"
                               Text=""
                               Margin="14,0,0,0"
                               Foreground="{StaticResource MutedForegroundBrush}"/>
                </StackPanel>

                <!--  Right side: Run/Stop and Switch  -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RunButton"
                            Content="▶ Run"
                            Click="RunButton_Click"
                            Style="{StaticResource RunButtonStyle}"
                            ToolTip="F5 — also Ctrl+Enter (toggle)"/>
                    <Button x:Name="StopButton"
                            Content="■ Stop"
                            Click="StopButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            IsEnabled="False"
                            ToolTip="Shift+F5 — also Ctrl+Enter (toggle)"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Button Content="Switch to Project"
                            Click="SwitchToCode2Viz_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Open Code2Viz and close Animator"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Editor (+ Minimap) | Splitter | Canvas
              The editor+minimap pair is wrapped in a nested Grid so the GridSplitter
              between this pair and the canvas only resizes the editor side; the minimap
              column is Auto-sized (its own Width="100") and stays fixed when dragging.  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="2*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>       <!-- editor: absorbs resize -->
                    <ColumnDefinition Width="Auto"/>    <!-- minimap: stays at Width=100 -->
                </Grid.ColumnDefinitions>

                <avalonedit:TextEditor x:Name="Editor"
                                       Grid.Column="0"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       Background="{StaticResource BackgroundBrush}"
                                       Foreground="{StaticResource ForegroundBrush}"
                                       LineNumbersForeground="#5A5A5A"
                                       ShowLineNumbers="True"/>

                <minimap:MinimapControl x:Name="EditorMinimap"
                                        Grid.Column="1"
                                        Width="100"/>
            </Grid>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <c2a:AnimCanvas x:Name="Canvas" Grid.Column="2"/>
        </Grid>

        <GridSplitter Grid.Row="3"
                      Height="4"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"/>

        <!--  Console  -->
        <DockPanel Grid.Row="4"
                   Background="{StaticResource BackgroundBrush}"
                   LastChildFill="True">
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource SecondaryBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,1"
                    Padding="10,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Console"
                               Foreground="{StaticResource MutedForegroundBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="Clear"
                            Click="ClearConsoleButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="14,0,0,0"
                            Padding="8,3"/>
                </StackPanel>
            </Border>
            <ListBox x:Name="ConsoleList"
                     Background="{StaticResource BackgroundBrush}"
                     Foreground="{StaticResource ForegroundBrush}"
                     FontFamily="Consolas"
                     FontSize="12"
                     BorderThickness="0"
                     MouseDoubleClick="ConsoleList_MouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </DockPanel>
    </Grid>
</Window>
