<Window x:Class="Code2Viz.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick Color" Height="420" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SecondaryBackgroundBrush}">
    
    <Window.Resources>
        <Style TargetType="Button" x:Key="ColorButtonStyle">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="2">
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="TextBox" x:Key="ValueBoxStyle">
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left Panel: Basic Colors -->
        <StackPanel Grid.Column="0" Grid.Row="0">
            <TextBlock Text="Basic colours:" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,8"/>
            
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="{StaticResource TertiaryBackgroundBrush}" Padding="4">
                <UniformGrid Columns="8" Rows="6">
                    <!-- Row 1 -->
                    <Button Background="#FF0000" Tag="#FF0000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#FF8000" Tag="#FF8000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#FFFF00" Tag="#FFFF00" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#80FF00" Tag="#80FF00" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#00FF00" Tag="#00FF00" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#00FF80" Tag="#00FF80" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#00FFFF" Tag="#00FFFF" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#0080FF" Tag="#0080FF" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <!-- Row 2 -->
                    <Button Background="#0000FF" Tag="#0000FF" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#8000FF" Tag="#8000FF" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#FF00FF" Tag="#FF00FF" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#FF0080" Tag="#FF0080" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#804000" Tag="#804000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#408080" Tag="#408080" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#004080" Tag="#004080" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#408040" Tag="#408040" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <!-- Row 3 -->
                    <Button Background="#800000" Tag="#800000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#804000" Tag="#804000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#808000" Tag="#808000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#008000" Tag="#008000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#008080" Tag="#008080" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#000080" Tag="#000080" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#800080" Tag="#800080" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#808080" Tag="#808080" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <!-- Row 4 -->
                    <Button Background="#400000" Tag="#400000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#402000" Tag="#402000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#404000" Tag="#404000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#004000" Tag="#004000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#004040" Tag="#004040" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#000040" Tag="#000040" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#400040" Tag="#400040" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#404040" Tag="#404040" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <!-- Row 5: Grays -->
                    <Button Background="#000000" Tag="#000000" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#202020" Tag="#202020" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#404040" Tag="#404040" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#606060" Tag="#606060" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#808080" Tag="#808080" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#A0A0A0" Tag="#A0A0A0" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#C0C0C0" Tag="#C0C0C0" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#FFFFFF" Tag="#FFFFFF" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <!-- Row 6: Pastels -->
                    <Button Background="#FFB0B0" Tag="#FFB0B0" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#FFDAB0" Tag="#FFDAB0" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#FFFFB0" Tag="#FFFFB0" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#B0FFB0" Tag="#B0FFB0" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#B0FFFF" Tag="#B0FFFF" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#B0B0FF" Tag="#B0B0FF" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#FFB0FF" Tag="#FFB0FF" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="#E0E0E0" Tag="#E0E0E0" Click="ColorButton_Click" Style="{StaticResource ColorButtonStyle}"/>
                </UniformGrid>
            </Border>
        </StackPanel>

        <!-- Right Panel: Color Spectrum + Controls -->
        <Grid Grid.Column="2" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
            </Grid.ColumnDefinitions>

            <!-- Saturation/Value Canvas -->
            <Border Grid.Row="0" Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0">
                <Canvas x:Name="ColorCanvas" ClipToBounds="True" MouseLeftButtonDown="ColorCanvas_MouseDown" MouseMove="ColorCanvas_MouseMove" MouseLeftButtonUp="ColorCanvas_MouseUp">
                    <Canvas.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop x:Name="HueGradientStop" Color="Red" Offset="1"/>
                        </LinearGradientBrush>
                    </Canvas.Background>
                    <!-- Black overlay for value -->
                    <Rectangle x:Name="BlackOverlay" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}" Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="Black" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <!-- Crosshair marker -->
                    <Ellipse x:Name="ColorMarker" Width="12" Height="12" Stroke="White" StrokeThickness="2" Fill="Transparent" IsHitTestVisible="False"/>
                </Canvas>
            </Border>

            <!-- Hue Slider (vertical rainbow) -->
            <Border Grid.Row="0" Grid.Column="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Canvas x:Name="HueCanvas" Width="20" ClipToBounds="True" MouseLeftButtonDown="HueCanvas_MouseDown" MouseMove="HueCanvas_MouseMove" MouseLeftButtonUp="HueCanvas_MouseUp">
                    <Canvas.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF0000" Offset="0"/>
                            <GradientStop Color="#FFFF00" Offset="0.167"/>
                            <GradientStop Color="#00FF00" Offset="0.333"/>
                            <GradientStop Color="#00FFFF" Offset="0.5"/>
                            <GradientStop Color="#0000FF" Offset="0.667"/>
                            <GradientStop Color="#FF00FF" Offset="0.833"/>
                            <GradientStop Color="#FF0000" Offset="1"/>
                        </LinearGradientBrush>
                    </Canvas.Background>
                    <!-- Hue marker -->
                    <Rectangle x:Name="HueMarker" Width="20" Height="4" Fill="Transparent" Stroke="White" StrokeThickness="2" IsHitTestVisible="False"/>
                </Canvas>
            </Border>

            <!-- Bottom: Preview & Values -->
            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Color Preview -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Colour|Solid" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,4"/>
                    <Border Width="60" Height="40" BorderBrush="Gray" BorderThickness="1">
                        <Rectangle x:Name="PreviewRect" Fill="Red"/>
                    </Border>
                </StackPanel>

                <!-- HSL/RGB Values -->
                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hue:" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox x:Name="HueBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueBoxStyle}" TextChanged="HSL_TextChanged"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Sat:" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox x:Name="SatBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueBoxStyle}" TextChanged="HSL_TextChanged"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Lum:" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox x:Name="LumBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueBoxStyle}" TextChanged="HSL_TextChanged"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Red:" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox x:Name="RedBox" Grid.Row="0" Grid.Column="4" Style="{StaticResource ValueBoxStyle}" TextChanged="RGB_TextChanged"/>

                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Green:" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox x:Name="GreenBox" Grid.Row="1" Grid.Column="4" Style="{StaticResource ValueBoxStyle}" TextChanged="RGB_TextChanged"/>

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Blue:" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox x:Name="BlueBox" Grid.Row="2" Grid.Column="4" Style="{StaticResource ValueBoxStyle}" TextChanged="RGB_TextChanged"/>

                    <!-- Hex -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Hex:" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox x:Name="HexBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Style="{StaticResource ValueBoxStyle}" Width="100" TextChanged="Hex_TextChanged"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" IsDefault="True" Click="OkButton_Click" Style="{StaticResource RunButtonStyle}" Width="80" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True" Click="CancelButton_Click" Style="{StaticResource RibbonButtonStyle}" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
