<Window x:Class="Code2Viz.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure your new project" Height="350" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Language" Foreground="#CCCCCC" Margin="0,0,0,5"/>
            <ComboBox x:Name="LanguageBox" Margin="0,0,0,15" SelectedIndex="0">
                <ComboBoxItem Content="C#" Tag="CSharp"/>
                <ComboBoxItem Content="F#" Tag="FSharp"/>
            </ComboBox>

            <TextBlock Text="Project Name" Foreground="#CCCCCC" Margin="0,0,0,5"/>
            <TextBox x:Name="ProjectNameBox" Padding="5" Margin="0,0,0,15" Text="MyVizProject"/>

            <TextBlock Text="Location" Foreground="#CCCCCC" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="LocationBox" Padding="5" IsReadOnly="True" Text="C:\Zyeta\Projects"/>
                <Button Grid.Column="1" Content="..." Width="30" Margin="5,0,0,0" Click="BrowseButton_Click"/>
            </Grid>
            
            <TextBlock Text="Project will be created in:" Foreground="#888888" FontSize="11" Margin="0,0,0,5"/>
            <TextBlock x:Name="FinalPathText" Text="C:\Zyeta\Projects\MyVizProject" Foreground="#CCCCCC" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back" Width="80" Height="30" Margin="0,0,10,0" IsCancel="True"/>
                <Button Content="Create" Width="80" Height="30" Click="CreateButton_Click" IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
