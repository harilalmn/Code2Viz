<Window x:Class="Code2Viz.VideoExportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Video" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Export Animation as MP4 Video" FontSize="18" FontWeight="Bold" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1">
            <!-- Animation Settings -->
            <TextBlock Text="Animation Settings:" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,10" FontWeight="SemiBold"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Duration (seconds):" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Grid.Row="0"/>
                <Slider x:Name="SliderDuration" Grid.Column="1" Grid.Row="0"
                        Minimum="1" Maximum="60" Value="5"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock x:Name="TextDuration" Text="5" Grid.Column="2" Grid.Row="0"
                           Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>

                <TextBlock Text="Frames per second:" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Grid.Row="1" Margin="0,10,0,0"/>
                <Slider x:Name="SliderFps" Grid.Column="1" Grid.Row="1"
                        Minimum="15" Maximum="60" Value="30"
                        TickFrequency="15" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center" Margin="10,10,10,0"/>
                <TextBlock x:Name="TextFps" Text="30" Grid.Column="2" Grid.Row="1"
                           Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,10,0,0"/>

                <TextBlock Text="Bitrate (Mbps):" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Grid.Row="2" Margin="0,10,0,0"/>
                <Slider x:Name="SliderBitrate" Grid.Column="1" Grid.Row="2"
                        Minimum="1" Maximum="20" Value="5"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center" Margin="10,10,10,0"/>
                <TextBlock x:Name="TextBitrate" Text="5" Grid.Column="2" Grid.Row="2"
                           Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,10,0,0"/>
            </Grid>

            <TextBlock x:Name="TextFrameInfo" Text="Total frames: 150 | Estimated size: ~3 MB" Foreground="Gray" Margin="0,0,0,15" FontSize="11"/>

            <!-- Resolution Settings -->
            <TextBlock Text="Resolution:" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,10" FontWeight="SemiBold"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Preset:" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                <ComboBox x:Name="ComboResolution" Grid.Column="1" SelectionChanged="ComboResolution_SelectionChanged"
                          Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource ForegroundBrush}">
                    <ComboBoxItem Content="Canvas Size" IsSelected="True"/>
                    <ComboBoxItem Content="720p (1280×720)"/>
                    <ComboBoxItem Content="1080p (1920×1080)"/>
                    <ComboBoxItem Content="4K (3840×2160)"/>
                    <ComboBoxItem Content="Custom"/>
                </ComboBox>

                <TextBlock Text="Dimensions:" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" Grid.Row="1" Margin="0,10,0,0"/>
                <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="1" Margin="0,10,0,0">
                    <TextBox x:Name="TextWidth" Width="60" Text="1920" IsEnabled="False"
                             Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="Gray" Padding="4,2"/>
                    <TextBlock Text=" × " Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TextHeight" Width="60" Text="1080" IsEnabled="False"
                             Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="Gray" Padding="4,2"/>
                    <TextBlock x:Name="TextResolutionInfo" Text="" Foreground="Gray" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- Background Settings -->
            <TextBlock Text="Background:" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,10" FontWeight="SemiBold"/>

            <RadioButton x:Name="RadioCanvas" Content="Current Canvas Background" GroupName="Bg" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,8" IsChecked="True"/>
            <RadioButton x:Name="RadioWhite" Content="White" GroupName="Bg" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,8"/>
            <RadioButton x:Name="RadioBlack" Content="Black" GroupName="Bg" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,12"/>

            <CheckBox x:Name="CheckShowGrid" Content="Include Grid &amp; Axes" IsChecked="False" Foreground="{StaticResource ForegroundBrush}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" IsCancel="True" Style="{StaticResource RibbonButtonStyle}" Width="80" Margin="0,0,10,0"/>
            <Button Content="Export" Click="Export_Click" Style="{StaticResource RunButtonStyle}" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
