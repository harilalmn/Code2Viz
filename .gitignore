## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Bb]in/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Visual Studio 2017 auto generated files
Generated\ Files/

# Visual Studio Code
.vscode/

# Windows image file caches
Thumbs.db
ehthumbs.db

# Desktop.ini
Desktop.ini

# Recycle Bin
$RECYCLE.BIN/

# VS Code directory for project
.agent/
nul

# Test output
TestResults/
Tests/TestResults/
*.trx

# Build/test logs and transient scratch files
build*.log
build*.err
build*.out
build_output*.txt
build_error*.txt
cleanup_errors*.txt
msbuild.log
test_failure*.txt
tmpclaude-*-cwd

# Node.js
node_modules/

# Antigravity CLI local state
.antigravitycli/

# Inno Setup installer build output (built by release workflow / -LocalBuild)
installer/output/
