<Window x:Class="Code2Viz.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Code2Viz"
        mc:Ignorable="d"
        Title="Code2Viz API Documentation" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox" Margin="10" Padding="5" 
                     TextChanged="SearchBox_TextChanged"/>

            <TreeView x:Name="DocTree" Grid.Row="1" BorderThickness="0" Background="Transparent" 
                      SelectedItemChanged="DocTree_SelectedItemChanged" Margin="5">
            </TreeView>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

        <!-- Content Area -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="PrintBtn" Content="Print / Export PDF" Click="PrintBtn_Click" Padding="10,5"/>
                </StackPanel>
            </Border>

            <!-- Document Viewers -->
            <TabControl Grid.Row="1" Margin="0,5,0,0">
                <TabItem Header="C# Reference">
                    <FlowDocumentScrollViewer x:Name="DocViewer" VerticalScrollBarVisibility="Auto">
                        <FlowDocument>
                            <Paragraph FontSize="16" Foreground="Gray" TextAlignment="Center" Margin="0,50,0,0">
                                Select a class from the left to view C# documentation.
                            </Paragraph>
                        </FlowDocument>
                    </FlowDocumentScrollViewer>
                </TabItem>
                <TabItem Header="F# Reference">
                    <FlowDocumentScrollViewer x:Name="DocViewerFSharp" VerticalScrollBarVisibility="Auto">
                        <FlowDocument>
                            <Paragraph FontSize="16" Foreground="Gray" TextAlignment="Center" Margin="0,50,0,0">
                                Select a class from the left to view F# documentation and examples.
                            </Paragraph>
                        </FlowDocument>
                    </FlowDocumentScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
