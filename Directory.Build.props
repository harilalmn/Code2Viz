<Project>
  <!--
    Canonical version source for every C# project in the repo.
    The scripts/release.ps1 release script bumps these and mirrors the same
    value into installer.iss (#define MyAppVersion).
  -->
  <PropertyGroup>
    <Version>1.0.4</Version>
    <AssemblyVersion>1.0.4.0</AssemblyVersion>
    <FileVersion>1.0.4.0</FileVersion>
  </PropertyGroup>
</Project>