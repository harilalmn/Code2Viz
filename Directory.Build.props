<Project>
  <!--
    Canonical version source for every C# project in the repo.
    Calendar versioning: YEAR.MONTH.PATCH. The scripts/release.ps1 release
    script stamps YEAR/MONTH from the release date, increments PATCH within a
    month, and mirrors the same value into installer.iss (#define MyAppVersion).
  -->
  <PropertyGroup>
    <Version>2026.5.3</Version>
    <AssemblyVersion>2026.5.3.0</AssemblyVersion>
    <FileVersion>2026.5.3.0</FileVersion>
  </PropertyGroup>
</Project>