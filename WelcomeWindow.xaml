<Window
    x:Class="Code2Viz.WelcomeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Welcome to Code2Viz"
    Width="800"
    Height="450"
    Background="#1E1E1E"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Left Side: Branding/Recent  -->
        <Border Grid.Column="0" Background="#252526">
            <StackPanel Margin="40">
                <Image
                    Width="120"
                    Height="120"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left"
                    Source="pack://application:,,,/img/logo.png" />
                <TextBlock
                    Margin="0,0,0,20"
                    FontSize="18"
                    Foreground="#888888"
                    Text="Visual Geometry Environment" />

                <TextBlock
                    Margin="0,0,0,10"
                    FontSize="16"
                    Foreground="#E0E0E0"
                    Text="Recent Projects" />
                <TextBlock
                    x:Name="NoRecentProjectsText"
                    FontSize="13"
                    FontStyle="Italic"
                    Foreground="#666666"
                    Text="No recent projects"
                    Visibility="Collapsed" />
                <ListView
                    x:Name="RecentProjectsList"
                    MaxHeight="220"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#CCCCCC"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    SelectionChanged="RecentProjectsList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border
                                            x:Name="Bd"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#094771" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontSize="14"
                                    Foreground="White"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#888888"
                                    Text="{Binding Path}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <!--  Right Side: Actions  -->
        <StackPanel
            Grid.Column="1"
            Margin="40"
            VerticalAlignment="Center">
            <TextBlock
                Margin="0,0,0,30"
                FontSize="24"
                Foreground="White"
                Text="Get Started" />

            <Button
                x:Name="NewProjectBtn"
                Height="60"
                Margin="0,0,0,15"
                Background="#3E3E42"
                BorderThickness="0"
                Click="NewProjectBtn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="15"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!--  Icon placeholder  -->
                                <Path
                                    Grid.Column="0"
                                    Width="24"
                                    Height="24"
                                    Margin="0,0,15,0"
                                    Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                    Fill="White"
                                    Stretch="Uniform" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Create a new project" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button
                x:Name="OpenProjectBtn"
                Height="60"
                Background="#3E3E42"
                BorderThickness="0"
                Click="OpenProjectBtn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="15"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!--  Icon placeholder  -->
                                <Path
                                    Grid.Column="0"
                                    Width="24"
                                    Height="24"
                                    Margin="0,0,15,0"
                                    Data="M13,9V3.5L18.5,9M6,2C4.89,2 4,2.89 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2H6Z"
                                    Fill="White"
                                    Stretch="Uniform" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Open a local project" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
