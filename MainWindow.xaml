<Window
    x:Class="Code2Viz.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:canvas="clr-namespace:Code2Viz.Canvas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Code2Viz"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:project="clr-namespace:Code2Viz.Project"
    xmlns:search="clr-namespace:Code2Viz.Search"
    Title="Code2Viz - 2D Geometry Visualizer"
    Width="1200"
    Height="700"
    MinWidth="600"
    MinHeight="400"
    Background="{StaticResource BackgroundBrush}"
    Closing="Window_Closing"
    Icon="/img/logo.ico"
    KeyboardNavigation.TabNavigation="None"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    mc:Ignorable="d">

    <Window.InputBindings>
        <KeyBinding
            Key="F"
            Command="{Binding FormatCodeCommand}"
            Modifiers="Ctrl+Shift" />
        <KeyBinding
            Key="S"
            Command="{Binding SaveCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="O"
            Command="{Binding OpenCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="N"
            Command="{Binding NewCommand}"
            Modifiers="Ctrl" />
        <KeyBinding Key="F5" Command="{Binding RunCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <!--  Title Bar  -->
            <RowDefinition Height="Auto" />
            <!--  Menu Bar  -->
            <RowDefinition Height="Auto" />
            <!--  Drawing Toolbar  -->
            <RowDefinition Height="Auto" />
            <!--  Main Content  -->
            <RowDefinition Height="*" />
            <!--  Footer  -->
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <!--  Title Bar with Logo  -->
        <Border
            Grid.Row="0"
            Padding="12,12"
            Background="{StaticResource SecondaryBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">
            <Image
                Height="80"
                HorizontalAlignment="Left"
                Source="/img/logo.png" />
        </Border>

        <!--  Menu Bar  -->
        <Border
            Grid.Row="1"
            Background="{StaticResource SecondaryBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Menu Grid.Column="0" Background="Transparent">
                    <Menu.Resources>
                        <Style TargetType="MenuItem">
                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="8,6" />
                        </Style>
                        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
                            <Setter Property="Foreground" Value="#1E1E1E" />
                            <Setter Property="Padding" Value="8,4" />
                        </Style>
                    </Menu.Resources>

                    <!--  File Menu  -->
                    <MenuItem Header="_File">
                        <MenuItem
                            Click="NewProjectButton_Click"
                            Header="_New Project"
                            InputGestureText="Ctrl+Shift+N"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="NewFileButton_Click"
                            Header="New _File"
                            InputGestureText="Ctrl+N"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="OpenButton_Click"
                            Header="_Open Project..."
                            InputGestureText="Ctrl+O"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="CloseProjectMenuItem_Click"
                            Header="_Close Project"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="SaveButton_Click"
                            Header="_Save"
                            InputGestureText="Ctrl+S"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="ExportButton_Click"
                            Header="_Export PNG..."
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="ExportGifButton_Click"
                            Header="Export _GIF Animation..."
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="ExportVideoButton_Click"
                            Header="Export _Video (MP4)..."
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="ExportDxfButton_Click"
                            Header="Export _DXF (AutoCAD)..."
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="ExportPdfButton_Click"
                            Header="Export _PDF..."
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="ExportSvgButton_Click"
                            Header="Export _SVG..."
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="ExportConsoleButton_Click"
                            Header="Export _Console..."
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="ExitMenuItem_Click"
                            Header="E_xit"
                            InputGestureText="Alt+F4"
                            Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!--  Edit Menu  -->
                    <MenuItem Header="_Edit" SubmenuOpened="EditMenu_SubmenuOpened">
                        <MenuItem
                            Click="FormatButton_Click"
                            Header="_Format Code"
                            InputGestureText="Ctrl+Shift+F"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            x:Name="AutoIndentMenuItem"
                            Header="_Auto Indent"
                            IsCheckable="True"
                            IsChecked="True"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="DuplicateLineMenuItem_Click"
                            Header="_Duplicate Line"
                            InputGestureText="Shift+Alt+Down"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="DeleteLineMenuItem_Click"
                            Header="D_elete Line"
                            InputGestureText="Ctrl+Shift+D"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="MoveLineUpMenuItem_Click"
                            Header="Move Line _Up"
                            InputGestureText="Alt+Up"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="MoveLineDownMenuItem_Click"
                            Header="Move Line D_own"
                            InputGestureText="Alt+Down"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="AddCursorAboveMenuItem_Click"
                            Header="Add Cursor A_bove"
                            InputGestureText="Ctrl+Alt+Up"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="AddCursorBelowMenuItem_Click"
                            Header="Add Cursor Bel_ow"
                            InputGestureText="Ctrl+Alt+Down"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="ToggleCommentMenuItem_Click"
                            Header="_Toggle Comment"
                            InputGestureText="Ctrl+/"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="RefactorMenuItem_Click"
                            Header="_Quick Actions / Refactor..."
                            InputGestureText="Ctrl+."
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            x:Name="InsertColorMenuItem"
                            Click="InsertColorMenuItem_Click"
                            Header="_Insert Color..."
                            InputGestureText="Ctrl+Shift+K"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="FindMenuItem_Click"
                            Header="_Find..."
                            InputGestureText="Ctrl+F"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="FindReplaceMenuItem_Click"
                            Header="Find and _Replace..."
                            InputGestureText="Ctrl+H"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="FindInFilesMenuItem_Click"
                            Header="Find in F_iles..."
                            InputGestureText="Ctrl+Shift+F"
                            Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!--  Project Menu  -->
                    <MenuItem Header="_Project">
                        <MenuItem
                            Click="ManagePackagesMenuItem_Click"
                            Header="Manage _NuGet Packages..."
                            Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!--  Draw Menu  -->
                    <MenuItem x:Name="DrawMenu" Header="_Draw">
                        <MenuItem
                            Click="DrawPoint_Click"
                            Header="_Point"
                            InputGestureText="P"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="DrawLine_Click"
                            Header="_Line"
                            InputGestureText="L"
                            Style="{StaticResource MenuItemStyle}" />
                        <!--  Circle Submenu  -->
                        <MenuItem Header="_Circle" Style="{StaticResource MenuItemStyle}">
                            <MenuItem
                                Click="DrawCircle_CenterRadius_Click"
                                Header="Center, _Radius"
                                InputGestureText="C"
                                Style="{StaticResource MenuItemStyle}" />
                            <MenuItem
                                Click="DrawCircle_CenterDiameter_Click"
                                Header="Center, _Diameter"
                                Style="{StaticResource MenuItemStyle}" />
                            <MenuItem
                                Click="DrawCircle_TwoPoints_Click"
                                Header="_2 Points"
                                Style="{StaticResource MenuItemStyle}" />
                            <MenuItem
                                Click="DrawCircle_ThreePoints_Click"
                                Header="_3 Points"
                                Style="{StaticResource MenuItemStyle}" />
                        </MenuItem>
                        <!--  Arc Submenu  -->
                        <MenuItem Header="_Arc" Style="{StaticResource MenuItemStyle}">
                            <MenuItem
                                Click="DrawArc_ThreePoints_Click"
                                Header="_3 Points"
                                Style="{StaticResource MenuItemStyle}" />
                            <Separator />
                            <MenuItem
                                Click="DrawArc_StartCenterEnd_Click"
                                Header="Start, Center, End"
                                Style="{StaticResource MenuItemStyle}" />
                            <MenuItem
                                Click="DrawArc_StartCenterAngle_Click"
                                Header="Start, Center, Angle"
                                Style="{StaticResource MenuItemStyle}" />
                            <MenuItem
                                Click="DrawArc_StartCenterLength_Click"
                                Header="Start, Center, Length"
                                Style="{StaticResource MenuItemStyle}" />
                            <Separator />
                            <MenuItem
                                Click="DrawArc_StartEndAngle_Click"
                                Header="Start, End, Angle"
                                Style="{StaticResource MenuItemStyle}" />
                            <MenuItem
                                Click="DrawArc_StartEndRadius_Click"
                                Header="Start, End, Radius"
                                Style="{StaticResource MenuItemStyle}" />
                            <Separator />
                            <MenuItem
                                Click="DrawArc_CenterStartEnd_Click"
                                Header="Center, Start, End"
                                Style="{StaticResource MenuItemStyle}" />
                            <MenuItem
                                Click="DrawArc_CenterStartAngle_Click"
                                Header="Center, Start, Angle"
                                Style="{StaticResource MenuItemStyle}" />
                            <MenuItem
                                Click="DrawArc_CenterStartLength_Click"
                                Header="Center, Start, Length"
                                Style="{StaticResource MenuItemStyle}" />
                            <Separator />
                            <MenuItem
                                Click="DrawArc_Continue_Click"
                                Header="Continue"
                                Style="{StaticResource MenuItemStyle}" />
                        </MenuItem>
                        <MenuItem
                            Click="DrawRect_Click"
                            Header="_Rectangle"
                            InputGestureText="R"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="DrawEllipse_Click"
                            Header="_Ellipse"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="DrawPolygon_Click"
                            Header="Pol_ygon"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="DrawPolyline_Click"
                            Header="Poly_line"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="DrawBezier_Click"
                            Header="_Bezier"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="DrawSpline_Click"
                            Header="_Spline"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="DrawArrow_Click"
                            Header="Arro_w"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="DrawText_Click"
                            Header="_Text"
                            Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!--  View Menu  -->
                    <MenuItem Header="_View">
                        <MenuItem
                            x:Name="GridMenuItem"
                            Click="GridMenuItem_Click"
                            Header="Show _Grid"
                            IsCheckable="True"
                            IsChecked="True"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="ZoomToShapeMenuItem_Click"
                            Header="_Zoom To Shape..."
                            InputGestureText="Ctrl+G"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            x:Name="InlayHintsMenuItem"
                            Click="InlayHintsMenuItem_Click"
                            Header="_Inlay Hints"
                            IsCheckable="True"
                            IsChecked="False"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            x:Name="SemanticHighlightingMenuItem"
                            Click="SemanticHighlightingMenuItem_Click"
                            Header="_Semantic Highlighting"
                            IsCheckable="True"
                            IsChecked="True"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            x:Name="CodeLensMenuItem"
                            Click="CodeLensMenuItem_Click"
                            Header="Code _Lens"
                            IsCheckable="True"
                            IsChecked="False"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="ClearButton_Click"
                            Header="_Clear Canvas"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            Click="ClearConsoleButton_Click"
                            Header="Clear C_onsole"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="ResetLayout_Click"
                            Header="_Reset Layout"
                            InputGestureText="Ctrl+R"
                            Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!--  Windows Menu  -->
                    <MenuItem Header="_Windows">
                        <MenuItem
                            x:Name="ShowProjectBrowserMenuItem"
                            Click="ShowProjectBrowserMenuItem_Click"
                            Header="_Project Browser"
                            IsCheckable="True"
                            IsChecked="False"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            x:Name="ShowOutlinerMenuItem"
                            Click="ShowOutlinerMenuItem_Click"
                            Header="_Outliner"
                            IsCheckable="True"
                            IsChecked="False"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            x:Name="ShowTimelineMenuItem"
                            Click="ShowTimelineMenuItem_Click"
                            Header="_Timeline"
                            IsCheckable="True"
                            IsChecked="False"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            x:Name="ShowCanvasMenuItem"
                            Click="ShowCanvasMenuItem_Click"
                            Header="C_anvas"
                            IsCheckable="True"
                            IsChecked="True"
                            Style="{StaticResource MenuItemStyle}" />
                        <MenuItem
                            x:Name="ShowConsoleMenuItem"
                            Click="ShowConsoleMenuItem_Click"
                            Header="Co_nsole"
                            IsCheckable="True"
                            IsChecked="True"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            x:Name="ShowPropertiesMenuItem"
                            Click="ShowPropertiesMenuItem_Click"
                            Header="_Properties"
                            InputGestureText="F4"
                            IsCheckable="True"
                            IsChecked="False"
                            Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!--  Run Menu  -->
                    <MenuItem Header="_Run">
                        <MenuItem
                            x:Name="RunMenuItem"
                            Click="RunButton_Click"
                            Header="_Run Code"
                            InputGestureText="F5"
                            Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!--  Help Menu  -->
                    <MenuItem Header="_Help">
                        <MenuItem
                            Click="HelpMenuItem_Click"
                            Header="_Shape Reference"
                            InputGestureText="F1"
                            Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem
                            Click="AboutMenuItem_Click"
                            Header="_About Code2Viz"
                            Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>
                </Menu>

                <!--  Run Button (kept for quick access)  -->
                <StackPanel
                    Grid.Column="1"
                    Margin="0,4,8,4"
                    Orientation="Horizontal">
                    <Button
                        x:Name="RunButton"
                        Padding="16,6"
                        Click="RunButton_Click"
                        Content="Run"
                        Style="{StaticResource RunButtonStyle}"
                        ToolTip="F5" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Drawing Toolbar removed - use Draw menu instead  -->

        <!--  Main Content: Code Editor + Canvas/Console + Project Browser/Outliner  -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <!--  Column 0: Code Editor (largest)  -->
                <ColumnDefinition
                    x:Name="CodeEditorColumn"
                    Width="2*"
                    MinWidth="300" />
                <!--  Column 1: Splitter  -->
                <ColumnDefinition Width="Auto" />
                <!--  Column 2: Canvas/Console  -->
                <ColumnDefinition
                    x:Name="CanvasConsoleColumn"
                    Width="*"
                    MinWidth="200" />
                <!--  Column 3: Splitter  -->
                <ColumnDefinition Width="Auto" />
                <!--  Column 4: Project Browser/Outliner  -->
                <ColumnDefinition
                    x:Name="RightPanelColumn"
                    Width="0"
                    MinWidth="0" />
                <!--  Column 5: Properties Splitter  -->
                <ColumnDefinition x:Name="PropertiesSplitterColumn" Width="0" />
                <!--  Column 6: Docked Properties Panel  -->
                <ColumnDefinition
                    x:Name="PropertiesColumn"
                    Width="0"
                    MinWidth="0" />
            </Grid.ColumnDefinitions>

            <!--  Project Browser and Outliner (Right Panel)  -->
            <Border
                x:Name="ProjectBrowserPanel"
                Grid.Column="4"
                Background="{StaticResource SecondaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0"
                Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition x:Name="OutlinerSplitterRow" Height="0" />
                        <RowDefinition x:Name="OutlinerHeaderRow" Height="0" />
                        <RowDefinition x:Name="OutlinerTreeRow" Height="0" />
                    </Grid.RowDefinitions>

                    <Border
                        Padding="10,8"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                        <TextBlock
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="{StaticResource ForegroundBrush}"
                            Text="EXPLORER" />
                    </Border>

                    <TreeView
                        x:Name="ProjectTreeView"
                        Grid.Row="1"
                        Padding="0,5"
                        Background="Transparent"
                        BorderThickness="0"
                        SelectedItemChanged="ProjectTreeView_SelectedItemChanged"
                        MouseDoubleClick="ProjectTreeView_MouseDoubleClick"
                        PreviewMouseRightButtonDown="ProjectTreeView_PreviewMouseRightButtonDown">
                        <TreeView.Resources>
                            <!--  Expander Toggle Button Style  -->
                            <Style x:Key="ExpandCollapseToggleStyle" TargetType="{x:Type ToggleButton}">
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Width" Value="16" />
                                <Setter Property="Height" Value="16" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border
                                                Width="16"
                                                Height="16"
                                                Padding="5"
                                                Background="Transparent">
                                                <Path
                                                    x:Name="ExpandPath"
                                                    Data="M0,0 L0,6 L6,0 z"
                                                    Fill="{StaticResource ForegroundBrush}"
                                                    RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="135" />
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ExpandPath" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="180" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="ExpandPath" Property="Fill" Value="{StaticResource ForegroundBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ExpandPath" Property="Fill" Value="{StaticResource AccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.Resources>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type project:ProjectTreeItem}" ItemsSource="{Binding Children}">
                                <StackPanel Margin="0,2" Orientation="Horizontal">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Source="{Binding Icon}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource ForegroundBrush}"
                                        Text="{Binding Name}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="IsExpanded" Value="True" />
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                                <Setter Property="Padding" Value="4,2" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="19" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition />
                                                </Grid.RowDefinitions>
                                                <ToggleButton
                                                    x:Name="Expander"
                                                    ClickMode="Press"
                                                    IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                    Style="{StaticResource ExpandCollapseToggleStyle}" />
                                                <Border
                                                    x:Name="Bd"
                                                    Grid.Column="1"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    SnapsToDevicePixels="true">
                                                    <ContentPresenter
                                                        x:Name="PART_Header"
                                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                        ContentSource="Header"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                </Border>
                                                <ItemsPresenter
                                                    x:Name="ItemsHost"
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Grid.ColumnSpan="2" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="HasItems" Value="false">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#37373D" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2D2E" />
                                        <Setter Property="Cursor" Value="Hand" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True" />
                                            <Condition Property="IsSelectionActive" Value="False" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="#37373D" />
                                        <Setter Property="Foreground" Value="White" />
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                    <!--  Splitter between Explorer and Outliner  -->
                    <GridSplitter
                        x:Name="OutlinerSplitter"
                        Grid.Row="2"
                        Height="4"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Background="{StaticResource BorderBrush}"
                        ResizeBehavior="PreviousAndNext"
                        Visibility="Collapsed" />

                    <!--  Outliner Header  -->
                    <Border
                        x:Name="OutlinerHeader"
                        Grid.Row="3"
                        Padding="10,8"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Visibility="Collapsed">
                        <TextBlock
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="{StaticResource ForegroundBrush}"
                            Text="OUTLINER" />
                    </Border>

                    <!--  Outliner TreeView  -->
                    <TreeView
                        x:Name="OutlinerTreeView"
                        Grid.Row="4"
                        Padding="0,5"
                        Background="Transparent"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        VirtualizingStackPanel.IsVirtualizing="True"
                        VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Click="OutlinerExpandAll_Click" Header="Expand All" />
                                <MenuItem Click="OutlinerCollapseAll_Click" Header="Collapse All" />
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.Resources>
                            <Style x:Key="OutlinerExpandCollapseToggleStyle" TargetType="{x:Type ToggleButton}">
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Width" Value="16" />
                                <Setter Property="Height" Value="16" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border
                                                Width="16"
                                                Height="16"
                                                Padding="5"
                                                Background="Transparent">
                                                <Path
                                                    x:Name="ExpandPath"
                                                    Data="M0,0 L0,6 L6,0 z"
                                                    Fill="{StaticResource ForegroundBrush}"
                                                    RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="135" />
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ExpandPath" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="180" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ExpandPath" Property="Fill" Value="{StaticResource AccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.Resources>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel
                                    Margin="0,2"
                                    MouseEnter="OutlinerItem_MouseEnter"
                                    MouseLeave="OutlinerItem_MouseLeave"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource ForegroundBrush}"
                                        Text="{Binding DisplayName}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="Gray"
                                        Text=" ["
                                        Visibility="{Binding IsShape, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock
                                        x:Name="IdLink"
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        Foreground="{StaticResource AccentBrush}"
                                        MouseLeftButtonDown="OutlinerIdLink_Click"
                                        Text="{Binding Id}"
                                        TextDecorations="Underline"
                                        Visibility="{Binding IsShape, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="Gray"
                                        Text="]"
                                        Visibility="{Binding IsShape, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="IsExpanded" Value="True" />
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                                <Setter Property="Padding" Value="4,2" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="19" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition />
                                                </Grid.RowDefinitions>
                                                <ToggleButton
                                                    x:Name="Expander"
                                                    ClickMode="Press"
                                                    IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                    Style="{StaticResource OutlinerExpandCollapseToggleStyle}" />
                                                <Border
                                                    x:Name="Bd"
                                                    Grid.Column="1"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    SnapsToDevicePixels="true">
                                                    <ContentPresenter
                                                        x:Name="PART_Header"
                                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                        ContentSource="Header"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                </Border>
                                                <ItemsPresenter
                                                    x:Name="ItemsHost"
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Grid.ColumnSpan="2" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="HasItems" Value="false">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                                </Trigger>
                                                <Trigger Property="IsExpanded" Value="false">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#37373D" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2D2E" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <!--  Splitter between Canvas/Console and Right Panel  -->
            <GridSplitter
                x:Name="RightPanelSplitter"
                Grid.Column="3"
                Width="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="{StaticResource BorderBrush}"
                Cursor="SizeWE"
                ResizeBehavior="PreviousAndNext"
                Visibility="Collapsed" />

            <!--  Canvas, Timeline, and Console  -->
            <Grid x:Name="CanvasConsoleGrid" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition
                        x:Name="CanvasRow"
                        Height="3*"
                        MinHeight="200" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition
                        x:Name="TimelineRow"
                        Height="0"
                        MinHeight="0" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition
                        x:Name="ConsoleRow"
                        Height="*"
                        MinHeight="80"
                        MaxHeight="500" />
                </Grid.RowDefinitions>

                <!--  Canvas  -->
                <Border
                    Grid.Row="0"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                    <Grid>
                        <canvas:RenderCanvas x:Name="RenderCanvas" />

                        <!--  Animation Controls Overlay  -->
                        <Border
                            x:Name="AnimationControlsPanel"
                            Margin="0,0,0,20"
                            Padding="12,8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Background="#CC1E1E1E"
                            CornerRadius="8"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Button
                                    x:Name="PlayPauseBtn"
                                    Click="PlayPause_Click"
                                    Content="▶"
                                    Style="{StaticResource MediaButtonStyle}"
                                    ToolTip="Play/Pause" />
                                <Button
                                    x:Name="StopBtn"
                                    Click="Stop_Click"
                                    Content="■"
                                    Style="{StaticResource MediaButtonStyle}"
                                    ToolTip="Stop" />
                                <TextBlock
                                    Margin="12,0,4,0"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Text="Speed:" />
                                <Slider
                                    x:Name="SpeedSlider"
                                    Width="80"
                                    VerticalAlignment="Center"
                                    Maximum="4"
                                    Minimum="0.25"
                                    ValueChanged="SpeedSlider_ValueChanged"
                                    Value="1" />
                                <TextBlock
                                    x:Name="SpeedText"
                                    Width="30"
                                    Margin="4,0,12,0"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Text="1x" />
                                <TextBlock
                                    x:Name="TimeDisplay"
                                    VerticalAlignment="Center"
                                    Foreground="LightGray"
                                    Text="0.00s" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!--  Splitter between Canvas and Timeline  -->
                <GridSplitter
                    x:Name="TimelineSplitter"
                    Grid.Row="1"
                    Height="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Background="{StaticResource BorderBrush}"
                    Cursor="SizeNS"
                    ResizeBehavior="PreviousAndNext"
                    ToolTip="Drag to resize."
                    Visibility="Collapsed" />

                <!--  Timeline Panel  -->
                <local:TimelinePanel
                    x:Name="TimelinePanel"
                    Grid.Row="2"
                    Visibility="Collapsed" />

                <!--  Bottom Panel (Console and Find Results) with integrated resize handle  -->
                <Border
                    x:Name="ConsolePanel"
                    Grid.Row="3"
                    Grid.RowSpan="2"
                    Background="{StaticResource SecondaryBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Resize Handle at top of console  -->
                        <Border
                            x:Name="ConsoleSplitter"
                            Grid.Row="0"
                            Height="6"
                            Background="#3F3F46"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Cursor="SizeNS"
                            MouseLeftButtonDown="ConsoleSplitter_MouseLeftButtonDown"
                            MouseLeftButtonUp="ConsoleSplitter_MouseLeftButtonUp"
                            MouseMove="ConsoleSplitter_MouseMove"
                            ToolTip="Drag to resize. Double-click to reset.">
                            <Rectangle
                                Width="40"
                                Height="3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Fill="#606060"
                                RadiusX="1.5"
                                RadiusY="1.5" />
                        </Border>

                        <TabControl
                            x:Name="BottomTabControl"
                            Grid.Row="1"
                            Background="{StaticResource SecondaryBackgroundBrush}"
                            BorderThickness="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Background" Value="{StaticResource TertiaryBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border
                                                x:Name="Border"
                                                Margin="0,0,2,0"
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1,1,1,0"
                                                CornerRadius="4,4,0,0">
                                                <ContentPresenter ContentSource="Header" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#404040" />
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True" />
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!--  Console Tab  -->
                        <TabItem x:Name="ConsoleTab">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="Console" />
                                    <Button
                                        Click="CloseConsoleTab_Click"
                                        Content="x"
                                        Style="{StaticResource TabCloseButtonStyle}"
                                        ToolTip="Close" />
                                </StackPanel>
                            </TabItem.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Console Header  -->
                                <Border
                                    Grid.Row="0"
                                    Padding="8,4"
                                    Background="{StaticResource TertiaryBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                        <Button
                                            x:Name="ClearConsoleButton"
                                            Padding="8,4"
                                            Click="ClearConsoleButton_Click"
                                            Content="Clear"
                                            Style="{StaticResource RibbonButtonStyle}" />
                                        <Button
                                            x:Name="ExportConsoleButton"
                                            Margin="4,0,0,0"
                                            Padding="8,4"
                                            Click="ExportConsoleButton_Click"
                                            Content="Export"
                                            Style="{StaticResource RibbonButtonStyle}" />
                                    </StackPanel>
                                </Border>

                                <!--  Console Output  -->
                                <ListBox
                                    x:Name="ConsoleListBox"
                                    Grid.Row="1"
                                    Background="{StaticResource BackgroundBrush}"
                                    BorderThickness="0"
                                    KeyDown="ConsoleListBox_KeyDown"
                                    MouseDoubleClick="ConsoleListBox_MouseDoubleClick"
                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                    SelectionMode="Extended">
                                    <ListBox.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Click="ConsoleCopy_Click"
                                                Header="Copy"
                                                InputGestureText="Ctrl+C">
                                                <MenuItem.Icon>
                                                    <TextBlock FontSize="12" Text="📋" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem
                                                Click="ConsoleSelectAll_Click"
                                                Header="Select All"
                                                InputGestureText="Ctrl+A" />
                                            <Separator />
                                            <MenuItem Click="ClearConsoleButton_Click" Header="Clear" />
                                        </ContextMenu>
                                    </ListBox.ContextMenu>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="4,2" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#3399FF" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <!--  File:Line prefix for clickable errors  -->
                                                <TextBlock FontFamily="Cascadia Code, Consolas, Courier New" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#808080" />
                                                            <Setter Property="Text" Value="{Binding ModuleName, StringFormat='[{0}:'}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsClickable}" Value="True">
                                                                    <Setter Property="Foreground" Value="#4EC9B0" />
                                                                    <Setter Property="Cursor" Value="Hand" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    FontFamily="Cascadia Code, Consolas, Courier New"
                                                    FontSize="12"
                                                    Text="{Binding LineNumber}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#808080" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsClickable}" Value="True">
                                                                    <Setter Property="Foreground" Value="#4EC9B0" />
                                                                    <Setter Property="Cursor" Value="Hand" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    FontFamily="Cascadia Code, Consolas, Courier New"
                                                    FontSize="12"
                                                    Foreground="#808080"
                                                    Text="] " />
                                                <!--  Message  -->
                                                <TextBlock
                                                    FontFamily="Cascadia Code, Consolas, Courier New"
                                                    FontSize="12"
                                                    Text="{Binding Message}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FF5555" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>

                        <!--  Find Results Tab  -->
                        <TabItem x:Name="FindResultsTab" Visibility="Collapsed">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="Find Results" />
                                    <Button
                                        Click="CloseFindResultsTab_Click"
                                        Content="x"
                                        Style="{StaticResource TabCloseButtonStyle}"
                                        ToolTip="Close" />
                                </StackPanel>
                            </TabItem.Header>
                            <search:FindResultsPanel x:Name="FindResultsPanel" />
                        </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>

            <!--  Splitter between Code Editor and Canvas/Console  -->
            <GridSplitter
                x:Name="CodeEditorSplitter"
                Grid.Column="1"
                Width="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="{StaticResource BorderBrush}"
                Cursor="SizeWE"
                ResizeBehavior="PreviousAndNext" />

            <!--  Code Editor with Tabs  -->
            <Border Grid.Column="0" Background="{StaticResource SecondaryBackgroundBrush}">
                <TabControl
                    x:Name="MainTabControl"
                    Background="{StaticResource SecondaryBackgroundBrush}"
                    BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="{StaticResource TertiaryBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                            <Setter Property="Padding" Value="12,6" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border
                                            x:Name="Border"
                                            Margin="0,0,2,0"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1,1,1,0"
                                            CornerRadius="4,4,0,0">
                                            <ContentPresenter ContentSource="Header" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!--  Code Tab  -->
                    <TabItem Header="Code">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  File Tabs  -->
                            <!--  File Tabs  -->
                            <ListBox
                                x:Name="FileTabs"
                                Grid.Row="0"
                                Padding="0"
                                Background="{StaticResource SecondaryBackgroundBrush}"
                                BorderThickness="0"
                                SelectionChanged="FileTabs_SelectionChanged">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="#969696" />
                                        <Setter Property="Padding" Value="10,6" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Grid Background="{TemplateBinding Background}">
                                                        <!--  Top Accent Border (Hidden by default)  -->
                                                        <Border
                                                            x:Name="AccentBorder"
                                                            Height="2"
                                                            VerticalAlignment="Top"
                                                            Background="{StaticResource AccentBrush}"
                                                            Visibility="Hidden" />

                                                        <ContentPresenter Margin="{TemplateBinding Padding}" />

                                                        <!--  Right separator  -->
                                                        <Border
                                                            Width="1"
                                                            Margin="0,4"
                                                            HorizontalAlignment="Right"
                                                            Background="{StaticResource BorderBrush}"
                                                            Opacity="0.5" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2D2D2D" />
                                                            <Setter Property="Foreground" Value="#E0E0E0" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#1E1E1E" /> 
                                                            <!--  Match Editor Background  -->
                                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                                            <Setter TargetName="AccentBorder" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                            <!--  File Name  -->
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                Text="{Binding FileName}" />

                                            <!--  Unsaved Indicator  -->
                                            <Ellipse
                                                Width="8"
                                                Height="8"
                                                Margin="6,1,0,0"
                                                Fill="{StaticResource ForegroundBrush}"
                                                Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVisibilityConverter}}" />

                                            <!--  Close Button  -->
                                            <Button
                                                Width="18"
                                                Height="18"
                                                Margin="8,0,0,0"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="CloseTab_Click"
                                                Cursor="Hand"
                                                Tag="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border
                                                                        x:Name="BtnBorder"
                                                                        Background="Transparent"
                                                                        CornerRadius="2">
                                                                        <Path
                                                                            x:Name="IconPath"
                                                                            Width="8"
                                                                            Height="8"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Data="M 0,0 L 8,8 M 0,8 L 8,0"
                                                                            Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                            StrokeThickness="1.5" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#404040" />
                                                                            <Setter TargetName="IconPath" Property="Stroke" Value="White" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!--  Breadcrumb Navigation Bar  -->
                            <Border
                                Grid.Row="1"
                                Padding="8,4"
                                Background="#252526"
                                BorderBrush="#3C3C3C"
                                BorderThickness="0,0,0,1">
                                <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal">
                                    <TextBlock
                                        x:Name="BreadcrumbText"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="#9CDCFE"
                                        Text="Ready" />
                                </StackPanel>
                            </Border>

                            <!--  Active Editor  -->
                            <Border Grid.Row="2" Background="#1E1E1E">
                                <avalonedit:TextEditor
                                    x:Name="CodeEditor"
                                    Padding="5"
                                    Background="#1E1E1E"
                                    BorderThickness="0"
                                    FontFamily="Consolas"
                                    FontSize="14"
                                    Foreground="#D4D4D4"
                                    HorizontalScrollBarVisibility="Auto"
                                    LineNumbersForeground="#858585"
                                    ShowLineNumbers="True"
                                    SyntaxHighlighting="C#"
                                    VerticalScrollBarVisibility="Visible"
                                    WordWrap="False" />
                            </Border>
                        </Grid>
                    </TabItem>

                    <!--  Settings Tab  -->
                    <TabItem Header="Settings">
                        <Grid Background="{StaticResource BackgroundBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="24">

                                    <!--  PROJECT SETTINGS SECTION  -->
                                    <Border
                                        Margin="0,0,0,24"
                                        Padding="20"
                                        Background="{StaticResource TertiaryBackgroundBrush}"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                                <TextBlock
                                                    FontSize="20"
                                                    FontWeight="Bold"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    Text="Project Settings" />
                                                <Border
                                                    Margin="12,0,0,0"
                                                    Padding="8,2"
                                                    VerticalAlignment="Center"
                                                    Background="#2D5A2D"
                                                    CornerRadius="4">
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="#90EE90"
                                                        Text="Saved per project" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock
                                                Margin="0,0,0,16"
                                                FontSize="12"
                                                Foreground="Gray"
                                                Text="These values control the default appearance of new shapes. Leave them empty to use shape-specific defaults."
                                                TextWrapping="Wrap" />

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="300" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!--  Stroke Color  -->
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,12"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Stroke Color:" />
                                                <TextBox
                                                    x:Name="SettingsColorBox"
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,12"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    TextChanged="ColorBox_TextChanged" />
                                                <Button
                                                    x:Name="SettingsColorBtn"
                                                    Grid.Row="0"
                                                    Grid.Column="2"
                                                    Width="30"
                                                    Height="30"
                                                    Margin="8,0,0,12"
                                                    VerticalAlignment="Top"
                                                    Background="#444444"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Click="PickColorButton_Click"
                                                    Content="..."
                                                    Foreground="White"
                                                    Tag="Stroke"
                                                    ToolTip="Pick Stroke Color" />

                                                <!--  Fill Color  -->
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,12"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Fill Color:" />
                                                <TextBox
                                                    x:Name="SettingsFillColorBox"
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,12"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    TextChanged="ColorBox_TextChanged" />
                                                <Button
                                                    x:Name="SettingsFillColorBtn"
                                                    Grid.Row="1"
                                                    Grid.Column="2"
                                                    Width="30"
                                                    Height="30"
                                                    Margin="8,0,0,12"
                                                    VerticalAlignment="Top"
                                                    Background="#444444"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Click="PickColorButton_Click"
                                                    Content="..."
                                                    Foreground="White"
                                                    Tag="Fill"
                                                    ToolTip="Pick Fill Color" />

                                                <!--  Canvas Background  -->
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,12"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Canvas Background:" />
                                                <TextBox
                                                    x:Name="SettingsCanvasColorBox"
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,12"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    TextChanged="ColorBox_TextChanged" />
                                                <Button
                                                    x:Name="SettingsCanvasColorBtn"
                                                    Grid.Row="2"
                                                    Grid.Column="2"
                                                    Width="30"
                                                    Height="30"
                                                    Margin="8,0,0,12"
                                                    VerticalAlignment="Top"
                                                    Background="#444444"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Click="PickColorButton_Click"
                                                    Content="..."
                                                    Foreground="White"
                                                    Tag="Canvas"
                                                    ToolTip="Pick Canvas Background" />

                                                <!--  Thickness  -->
                                                <TextBlock
                                                    Grid.Row="3"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,12"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Stroke Thickness:" />
                                                <TextBox
                                                    x:Name="SettingsThicknessBox"
                                                    Grid.Row="3"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,12"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}" />

                                                <!--  Line Type Scale  -->
                                                <TextBlock
                                                    Grid.Row="4"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Line Type Scale:" />
                                                <TextBox
                                                    x:Name="SettingsLineTypeScaleBox"
                                                    Grid.Row="4"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,16"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}" />

                                                <!--  Save Project Settings Button  -->
                                                <Button
                                                    Grid.Row="5"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Padding="20,8"
                                                    HorizontalAlignment="Left"
                                                    Click="SaveSettingsButton_Click"
                                                    Content="Save Project Settings"
                                                    Style="{StaticResource RunButtonStyle}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!--  APPLICATION SETTINGS SECTION  -->
                                    <Border
                                        Padding="20"
                                        Background="{StaticResource TertiaryBackgroundBrush}"
                                        BorderBrush="#666666"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                                <TextBlock
                                                    FontSize="20"
                                                    FontWeight="Bold"
                                                    Foreground="#CCCCCC"
                                                    Text="Application Settings" />
                                                <Border
                                                    Margin="12,0,0,0"
                                                    Padding="8,2"
                                                    VerticalAlignment="Center"
                                                    Background="#4A3A2D"
                                                    CornerRadius="4">
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="#FFB347"
                                                        Text="Saved globally" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock
                                                Margin="0,0,0,16"
                                                FontSize="12"
                                                Foreground="Gray"
                                                Text="These settings apply to all projects and are saved to your user profile."
                                                TextWrapping="Wrap" />

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="300" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!--  Export Settings Sub-header  -->
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.ColumnSpan="3"
                                                    Margin="0,0,0,12"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Export Settings" />

                                                <!--  Export Background  -->
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,12"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Export Background:" />
                                                <ComboBox
                                                    x:Name="SettingsExportBackgroundCombo"
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,12"
                                                    Padding="6"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="Black">
                                                    <ComboBox.ItemContainerStyle>
                                                        <Style TargetType="ComboBoxItem">
                                                            <Setter Property="Foreground" Value="Black" />
                                                        </Style>
                                                    </ComboBox.ItemContainerStyle>
                                                    <ComboBoxItem Content="Transparent" />
                                                    <ComboBoxItem Content="Canvas Background" />
                                                    <ComboBoxItem Content="White" />
                                                    <ComboBoxItem Content="Black" />
                                                    <ComboBoxItem Content="Light (White Smoke)" />
                                                    <ComboBoxItem Content="Light" Visibility="Collapsed" />
                                                </ComboBox>

                                                <!--  Include Grid  -->
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Include Grid in Export:" />
                                                <CheckBox
                                                    x:Name="SettingsIncludeGridCheck"
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,16"
                                                    VerticalAlignment="Center"
                                                    Content="Enabled"
                                                    Foreground="{StaticResource ForegroundBrush}" />

                                                <!--  Default Shape Settings Sub-header  -->
                                                <TextBlock
                                                    Grid.Row="3"
                                                    Grid.ColumnSpan="3"
                                                    Margin="0,8,0,12"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Shape Settings" />

                                                <!--  App Default Stroke Color  -->
                                                <TextBlock
                                                    Grid.Row="4"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Stroke Color:" />
                                                <TextBox
                                                    x:Name="AppSettingsColorBox"
                                                    Grid.Row="4"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    TextChanged="ColorBox_TextChanged" />
                                                <Button
                                                    x:Name="AppSettingsColorBtn"
                                                    Grid.Row="4"
                                                    Grid.Column="2"
                                                    Width="30"
                                                    Height="30"
                                                    Margin="8,0,0,8"
                                                    VerticalAlignment="Top"
                                                    Background="#444444"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Click="PickColorButton_Click"
                                                    Content="..."
                                                    Foreground="White"
                                                    Tag="AppStroke"
                                                    ToolTip="Pick Stroke Color" />

                                                <!--  App Default Fill Color  -->
                                                <TextBlock
                                                    Grid.Row="5"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Fill Color:" />
                                                <TextBox
                                                    x:Name="AppSettingsFillColorBox"
                                                    Grid.Row="5"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    TextChanged="ColorBox_TextChanged" />
                                                <Button
                                                    x:Name="AppSettingsFillColorBtn"
                                                    Grid.Row="5"
                                                    Grid.Column="2"
                                                    Width="30"
                                                    Height="30"
                                                    Margin="8,0,0,8"
                                                    VerticalAlignment="Top"
                                                    Background="#444444"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Click="PickColorButton_Click"
                                                    Content="..."
                                                    Foreground="White"
                                                    Tag="AppFill"
                                                    ToolTip="Pick Fill Color" />

                                                <!--  App Default Canvas Background  -->
                                                <TextBlock
                                                    Grid.Row="6"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Canvas Background:" />
                                                <TextBox
                                                    x:Name="AppSettingsCanvasColorBox"
                                                    Grid.Row="6"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    TextChanged="ColorBox_TextChanged" />
                                                <Button
                                                    x:Name="AppSettingsCanvasColorBtn"
                                                    Grid.Row="6"
                                                    Grid.Column="2"
                                                    Width="30"
                                                    Height="30"
                                                    Margin="8,0,0,8"
                                                    VerticalAlignment="Top"
                                                    Background="#444444"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Click="PickColorButton_Click"
                                                    Content="..."
                                                    Foreground="White"
                                                    Tag="AppCanvas"
                                                    ToolTip="Pick Canvas Background" />

                                                <!--  App Default Stroke Thickness  -->
                                                <TextBlock
                                                    Grid.Row="7"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Stroke Thickness:" />
                                                <TextBox
                                                    x:Name="AppSettingsThicknessBox"
                                                    Grid.Row="7"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}" />

                                                <!--  App Default Line Type Scale  -->
                                                <TextBlock
                                                    Grid.Row="8"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Default Line Type Scale:" />
                                                <TextBox
                                                    x:Name="AppSettingsLineTypeScaleBox"
                                                    Grid.Row="8"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,16"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}" />

                                                <!--  Snap Settings Sub-header  -->
                                                <TextBlock
                                                    Grid.Row="9"
                                                    Grid.ColumnSpan="3"
                                                    Margin="0,8,0,12"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Snap Settings (Ctrl+M to Measure)" />

                                                <!--  Snap Endpoints  -->
                                                <TextBlock
                                                    Grid.Row="10"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Snap to Endpoints:" />
                                                <CheckBox
                                                    x:Name="SnapEndpointCheck"
                                                    Grid.Row="10"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Content="Enabled"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    IsChecked="True" />

                                                <!--  Snap Midpoints  -->
                                                <TextBlock
                                                    Grid.Row="11"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Snap to Midpoints:" />
                                                <CheckBox
                                                    x:Name="SnapMidpointCheck"
                                                    Grid.Row="11"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Content="Enabled"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    IsChecked="True" />

                                                <!--  Snap Centers  -->
                                                <TextBlock
                                                    Grid.Row="12"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Snap to Centers:" />
                                                <CheckBox
                                                    x:Name="SnapCenterCheck"
                                                    Grid.Row="12"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Content="Enabled"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    IsChecked="True" />

                                                <!--  Snap Intersections  -->
                                                <TextBlock
                                                    Grid.Row="13"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Snap to Intersections:" />
                                                <CheckBox
                                                    x:Name="SnapIntersectionCheck"
                                                    Grid.Row="13"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Content="Enabled"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    IsChecked="True" />

                                                <!--  Snap Nearest  -->
                                                <TextBlock
                                                    Grid.Row="14"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Snap to Nearest:" />
                                                <CheckBox
                                                    x:Name="SnapNearestCheck"
                                                    Grid.Row="14"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Content="Enabled"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    IsChecked="True" />

                                                <!--  Snap Perpendicular  -->
                                                <TextBlock
                                                    Grid.Row="15"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Snap to Perpendicular:" />
                                                <CheckBox
                                                    x:Name="SnapPerpendicularCheck"
                                                    Grid.Row="15"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Content="Enabled"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    IsChecked="True" />

                                                <!--  Snap Extension  -->
                                                <TextBlock
                                                    Grid.Row="16"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Snap to Extension:" />
                                                <CheckBox
                                                    x:Name="SnapExtensionCheck"
                                                    Grid.Row="16"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Content="Enabled"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    IsChecked="True" />

                                                <!--  Snap Tangent  -->
                                                <TextBlock
                                                    Grid.Row="17"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Snap to Tangent:" />
                                                <CheckBox
                                                    x:Name="SnapTangentCheck"
                                                    Grid.Row="17"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,16"
                                                    VerticalAlignment="Center"
                                                    Content="Enabled"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    IsChecked="True" />

                                                <!--  Snap to Grid  -->
                                                <TextBlock
                                                    Grid.Row="18"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Snap to Grid:" />
                                                <CheckBox
                                                    x:Name="SnapToGridCheck"
                                                    Grid.Row="18"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,16"
                                                    VerticalAlignment="Center"
                                                    Content="Enabled (F9)"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    IsChecked="False" />

                                                <!--  Highlight Settings Sub-header  -->
                                                <TextBlock
                                                    Grid.Row="19"
                                                    Grid.ColumnSpan="3"
                                                    Margin="0,8,0,12"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Highlight Settings (Outliner Hover)" />

                                                <!--  Highlight Color  -->
                                                <TextBlock
                                                    Grid.Row="20"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,8"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Highlight Color:" />
                                                <TextBox
                                                    x:Name="HighlightColorBox"
                                                    Grid.Row="20"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,8"
                                                    Padding="6"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Yellow"
                                                    TextChanged="HighlightColorBox_TextChanged" />
                                                <Button
                                                    x:Name="HighlightColorBtn"
                                                    Grid.Row="20"
                                                    Grid.Column="2"
                                                    Width="30"
                                                    Height="30"
                                                    Margin="8,0,0,8"
                                                    Background="Yellow"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Click="PickHighlightColorButton_Click"
                                                    ToolTip="Pick Color" />

                                                <!--  Highlight Opacity  -->
                                                <TextBlock
                                                    Grid.Row="21"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Highlight Opacity:" />
                                                <StackPanel
                                                    Grid.Row="21"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,16"
                                                    Orientation="Horizontal">
                                                    <Slider
                                                        x:Name="HighlightOpacitySlider"
                                                        Width="200"
                                                        VerticalAlignment="Center"
                                                        Maximum="100"
                                                        Minimum="10"
                                                        ValueChanged="HighlightOpacitySlider_ValueChanged"
                                                        Value="40" />
                                                    <TextBlock
                                                        x:Name="HighlightOpacityText"
                                                        Width="40"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource ForegroundBrush}"
                                                        Text="40%" />
                                                </StackPanel>

                                                <!--  Canvas Settings Sub-header  -->
                                                <TextBlock
                                                    Grid.Row="22"
                                                    Grid.ColumnSpan="3"
                                                    Margin="0,8,0,12"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Canvas Settings" />

                                                <!--  Zoom to Fit on Run  -->
                                                <TextBlock
                                                    Grid.Row="23"
                                                    Grid.Column="0"
                                                    Margin="0,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Zoom to Fit on Run:" />
                                                <CheckBox
                                                    x:Name="SettingsZoomToFitCheck"
                                                    Grid.Row="23"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Checked="SettingsZoomToFitCheck_Changed"
                                                    Content="Enabled"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Unchecked="SettingsZoomToFitCheck_Changed" />

                                                <!--  Auto-update Canvas  -->
                                                <TextBlock
                                                    Grid.Row="24"
                                                    Grid.Column="0"
                                                    Margin="0,8,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Text="Auto-update Canvas:" />
                                                <CheckBox
                                                    x:Name="SettingsAutoUpdateCanvasCheck"
                                                    Grid.Row="24"
                                                    Grid.Column="1"
                                                    Margin="0,8,0,0"
                                                    VerticalAlignment="Center"
                                                    Checked="SettingsAutoUpdateCanvasCheck_Changed"
                                                    Content="Enabled (updates after 500ms pause)"
                                                    Foreground="{StaticResource ForegroundBrush}"
                                                    Unchecked="SettingsAutoUpdateCanvasCheck_Changed" />
                                            </Grid>

                                            <!--  Note about auto-save  -->
                                            <TextBlock
                                                Margin="0,16,0,0"
                                                FontSize="11"
                                                FontStyle="Italic"
                                                Foreground="Gray"
                                                Text="Application settings are saved automatically when changed." />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Border>

            <!--  Column 5: Properties Splitter  -->
            <GridSplitter
                x:Name="PropertiesSplitter"
                Grid.Column="5"
                Width="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="Transparent"
                Visibility="Collapsed" />

            <!--  Column 6: Docked Properties Panel  -->
            <Border
                x:Name="DockedPropertiesContainer"
                Grid.Column="6"
                Background="{StaticResource SecondaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0"
                Visibility="Collapsed" />

        </Grid>

        <!--  Footer  -->
        <Border
            Grid.Row="4"
            Padding="12,8"
            Background="{StaticResource SecondaryBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="StatusText"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource ForegroundBrush}"
                    Text="Ready"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />

                <CheckBox
                    x:Name="AutoUpdateCheck"
                    Grid.Column="1"
                    Margin="12,0"
                    VerticalAlignment="Center"
                    Checked="AutoUpdateCheck_Changed"
                    Content="Auto Update"
                    Foreground="{StaticResource ForegroundBrush}"
                    IsChecked="True"
                    Unchecked="AutoUpdateCheck_Changed" />

                <TextBlock
                    x:Name="CoordinatesText"
                    Grid.Column="2"
                    Margin="20,0"
                    VerticalAlignment="Center"
                    FontFamily="Consolas"
                    Foreground="{StaticResource ForegroundBrush}"
                    Text="X: 0.00  Y: 0.00" />

                <TextBlock
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource ForegroundBrush}"
                    Opacity="0.6"
                    Text="Scroll: Zoom | Middle-click: Pan" />
            </Grid>
        </Border>
    </Grid>
</Window>
