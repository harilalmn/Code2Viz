<Window x:Class="Code2Viz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:canvas="clr-namespace:Code2Viz.Canvas"
        xmlns:project="clr-namespace:Code2Viz.Project"
        xmlns:local="clr-namespace:Code2Viz"
        mc:Ignorable="d"
        Title="Code2Viz - 2D Geometry Visualizer"
        Icon="/img/logo.ico"
        Height="700" Width="1200"
        MinHeight="400" MinWidth="600"
        WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Ctrl+Shift" Command="{Binding FormatCodeCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}" />
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenCommand}" />
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewCommand}" />
        <KeyBinding Key="F5" Command="{Binding RunCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title Bar -->
            <RowDefinition Height="Auto" />
            <!-- Menu Bar -->
            <RowDefinition Height="Auto" />
            <!-- Drawing Toolbar -->
            <RowDefinition Height="Auto" />
            <!-- Main Content -->
            <RowDefinition Height="*" />
            <!-- Footer -->
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <!-- Title Bar with Logo -->
        <Border Grid.Row="0"
                Background="{StaticResource SecondaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,12">
            <Image Source="/img/logo_white.png" Height="80" HorizontalAlignment="Left" />
        </Border>

        <!-- Menu Bar -->
        <Border Grid.Row="1"
                Background="{StaticResource SecondaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Menu Grid.Column="0" Background="Transparent">
                    <Menu.Resources>
                        <Style TargetType="MenuItem">
                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="8,6" />
                        </Style>
                        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
                            <Setter Property="Foreground" Value="#1E1E1E" />
                            <Setter Property="Padding" Value="8,4" />
                        </Style>
                    </Menu.Resources>

                    <!-- File Menu -->
                    <MenuItem Header="_File">
                        <MenuItem Header="_New Project" Click="NewProjectButton_Click" InputGestureText="Ctrl+Shift+N" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="New _File" Click="NewFileButton_Click" InputGestureText="Ctrl+N" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem Header="_Open Project..." Click="OpenButton_Click" InputGestureText="Ctrl+O" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="_Close Project" Click="CloseProjectMenuItem_Click" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem Header="_Save" Click="SaveButton_Click" InputGestureText="Ctrl+S" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem Header="_Export PNG..." Click="ExportButton_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="Export _GIF Animation..." Click="ExportGifButton_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="Export _DXF (AutoCAD)..." Click="ExportDxfButton_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="Export _PDF..." Click="ExportPdfButton_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="Export _SVG..." Click="ExportSvgButton_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="Export _Console..." Click="ExportConsoleButton_Click" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem Header="E_xit" Click="ExitMenuItem_Click" InputGestureText="Alt+F4" Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!-- Edit Menu -->
                    <MenuItem Header="_Edit" SubmenuOpened="EditMenu_SubmenuOpened">
                        <MenuItem Header="_Format Code" Click="FormatButton_Click" InputGestureText="Ctrl+Shift+F" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem x:Name="AutoIndentMenuItem" Header="_Auto Indent" IsCheckable="True" IsChecked="True" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem Header="_Duplicate Line" Click="DuplicateLineMenuItem_Click" InputGestureText="Shift+Alt+Down" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="D_elete Line" Click="DeleteLineMenuItem_Click" InputGestureText="Ctrl+Shift+D" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="Move Line _Up" Click="MoveLineUpMenuItem_Click" InputGestureText="Alt+Up" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="Move Line D_own" Click="MoveLineDownMenuItem_Click" InputGestureText="Alt+Down" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem Header="_Toggle Comment" Click="ToggleCommentMenuItem_Click" InputGestureText="Ctrl+/" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem x:Name="InsertColorMenuItem" Header="_Insert Color..." Click="InsertColorMenuItem_Click" InputGestureText="Ctrl+Shift+K" Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!-- Project Menu -->
                    <MenuItem Header="_Project">
                        <MenuItem Header="Manage _NuGet Packages..." Click="ManagePackagesMenuItem_Click" Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!-- Draw Menu -->
                    <MenuItem Header="_Draw">
                        <MenuItem Header="_Point" Click="DrawPoint_Click" InputGestureText="P" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="_Line" Click="DrawLine_Click" InputGestureText="L" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="_Circle" Click="DrawCircle_Click" InputGestureText="C" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="_Rectangle" Click="DrawRect_Click" InputGestureText="R" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="_Ellipse" Click="DrawEllipse_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="_Arc" Click="DrawArc_Click" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem Header="Pol_ygon" Click="DrawPolygon_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="Poly_line" Click="DrawPolyline_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="_Bezier" Click="DrawBezier_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="_Spline" Click="DrawSpline_Click" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem Header="Arro_w" Click="DrawArrow_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="_Text" Click="DrawText_Click" Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!-- View Menu -->
                    <MenuItem Header="_View">
                        <MenuItem x:Name="GridMenuItem" Header="Show _Grid" IsCheckable="True" IsChecked="True" Click="GridMenuItem_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="_Zoom To Shape..." Click="ZoomToShapeMenuItem_Click" Style="{StaticResource MenuItemStyle}" InputGestureText="Ctrl+G" />
                        <Separator />
                        <MenuItem Header="_Clear Canvas" Click="ClearButton_Click" Style="{StaticResource MenuItemStyle}" />
                        <MenuItem Header="Clear C_onsole" Click="ClearConsoleButton_Click" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem Header="_Reset Layout" Click="ResetLayout_Click" Style="{StaticResource MenuItemStyle}" InputGestureText="Ctrl+R" />
                    </MenuItem>

                    <!-- Run Menu -->
                    <MenuItem Header="_Run">
                        <MenuItem x:Name="RunMenuItem" Header="_Run Code" Click="RunButton_Click" InputGestureText="F5" Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>

                    <!-- Help Menu -->
                    <MenuItem Header="_Help">
                        <MenuItem Header="_Shape Reference" Click="HelpMenuItem_Click" InputGestureText="F1" Style="{StaticResource MenuItemStyle}" />
                        <Separator />
                        <MenuItem Header="_About Code2Viz" Click="AboutMenuItem_Click" Style="{StaticResource MenuItemStyle}" />
                    </MenuItem>
                </Menu>

                <!-- Run Button (kept for quick access) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,4,8,4">
                    <Button x:Name="RunButton" Content="Run" Style="{StaticResource RunButtonStyle}" Click="RunButton_Click" ToolTip="F5" Padding="16,6" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Drawing Toolbar -->
        <Border Grid.Row="2"
                Background="{StaticResource SecondaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,4">
                <!-- Selection Tool (default) -->
                <Button x:Name="SelectToolBtn" Content="Select" ToolTip="Select (Esc)" Click="SelectTool_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,4,0" />
                <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="4,2"/>
                <!-- Basic Shape Tools -->
                <Button x:Name="DrawPointBtn" Content="Point" ToolTip="Draw Point (P)" Click="DrawPoint_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Button x:Name="DrawLineBtn" Content="Line" ToolTip="Draw Line (L)" Click="DrawLine_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Button x:Name="DrawCircleBtn" Content="Circle" ToolTip="Draw Circle (C)" Click="DrawCircle_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Button x:Name="DrawRectBtn" Content="Rect" ToolTip="Draw Rectangle (R)" Click="DrawRect_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Button x:Name="DrawEllipseBtn" Content="Ellipse" ToolTip="Draw Ellipse" Click="DrawEllipse_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Button x:Name="DrawArcBtn" Content="Arc" ToolTip="Draw Arc" Click="DrawArc_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="4,2"/>
                <!-- Multi-Point Shape Tools -->
                <Button x:Name="DrawPolygonBtn" Content="Polygon" ToolTip="Draw Polygon" Click="DrawPolygon_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Button x:Name="DrawPolylineBtn" Content="Polyline" ToolTip="Draw Polyline" Click="DrawPolyline_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Button x:Name="DrawBezierBtn" Content="Bezier" ToolTip="Draw Bezier Curve" Click="DrawBezier_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Button x:Name="DrawSplineBtn" Content="Spline" ToolTip="Draw Spline" Click="DrawSpline_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="4,2"/>
                <!-- Special Shape Tools -->
                <Button x:Name="DrawArrowBtn" Content="Arrow" ToolTip="Draw Arrow" Click="DrawArrow_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
                <Button x:Name="DrawTextBtn" Content="Text" ToolTip="Draw Text" Click="DrawText_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Main Content: Project Browser + Canvas + Editor + Properties -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Project Browser and Outliner -->
            <Border Grid.Column="0"
                    Background="{StaticResource SecondaryBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,8">
                        <TextBlock Text="EXPLORER"
                                   Foreground="{StaticResource ForegroundBrush}"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                    </Border>
                    
                    <TreeView x:Name="ProjectTreeView"
                              Grid.Row="1"
                              Background="Transparent"
                              BorderThickness="0"
                              MouseDoubleClick="ProjectTreeView_MouseDoubleClick"
                              PreviewMouseRightButtonDown="ProjectTreeView_PreviewMouseRightButtonDown"
                              Padding="0,5">
                        <TreeView.Resources>
                            <!-- Expander Toggle Button Style -->
                            <Style x:Key="ExpandCollapseToggleStyle" TargetType="{x:Type ToggleButton}">
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Width" Value="16"/>
                                <Setter Property="Height" Value="16"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border Background="Transparent" Height="16" Padding="5" Width="16">
                                                <Path x:Name="ExpandPath" 
                                                      Data="M0,0 L0,6 L6,0 z" 
                                                      Fill="{StaticResource ForegroundBrush}" 
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="135" />
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ExpandPath" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="180" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="ExpandPath" Property="Fill" Value="{StaticResource ForegroundBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ExpandPath" Property="Fill" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.Resources>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type project:ProjectTreeItem}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                             <Style TargetType="{x:Type TreeViewItem}">
                                 <Setter Property="IsExpanded" Value="True" />
                                 <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                 <Setter Property="Padding" Value="4,2"/>
                                 <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="19" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition />
                                                </Grid.RowDefinitions>
                                                <ToggleButton x:Name="Expander" 
                                                              ClickMode="Press" 
                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                              Style="{StaticResource ExpandCollapseToggleStyle}" />
                                                <Border x:Name="Bd" 
                                                        Grid.Column="1" 
                                                        Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                                        Padding="{TemplateBinding Padding}" 
                                                        SnapsToDevicePixels="true">
                                                    <ContentPresenter x:Name="PART_Header" 
                                                                      ContentSource="Header" 
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost" 
                                                                Grid.Row="1" 
                                                                Grid.Column="1" 
                                                                Grid.ColumnSpan="2" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="HasItems" Value="false">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#37373D" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2D2E" />
                                        <Setter Property="Cursor" Value="Hand" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True"/>
                                            <Condition Property="IsSelectionActive" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="#37373D"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                    <!-- Splitter between Explorer and Outliner -->
                    <GridSplitter Grid.Row="2"
                                  Height="4"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="{StaticResource BorderBrush}"
                                  ResizeBehavior="PreviousAndNext" />

                    <!-- Outliner Header -->
                    <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,8">
                        <TextBlock Text="OUTLINER"
                                   Foreground="{StaticResource ForegroundBrush}"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                    </Border>

                    <!-- Outliner TreeView -->
                    <TreeView x:Name="OutlinerTreeView"
                              Grid.Row="4"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0,5">
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Expand All" Click="OutlinerExpandAll_Click"/>
                                <MenuItem Header="Collapse All" Click="OutlinerCollapseAll_Click"/>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.Resources>
                            <Style x:Key="OutlinerExpandCollapseToggleStyle" TargetType="{x:Type ToggleButton}">
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Width" Value="16"/>
                                <Setter Property="Height" Value="16"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border Background="Transparent" Height="16" Padding="5" Width="16">
                                                <Path x:Name="ExpandPath"
                                                      Data="M0,0 L0,6 L6,0 z"
                                                      Fill="{StaticResource ForegroundBrush}"
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="135" />
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ExpandPath" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="180" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ExpandPath" Property="Fill" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.Resources>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,2"
                                            MouseEnter="OutlinerItem_MouseEnter"
                                            MouseLeave="OutlinerItem_MouseLeave">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text=" [" Foreground="Gray" VerticalAlignment="Center" Visibility="{Binding IsShape, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock x:Name="IdLink"
                                               Text="{Binding Id}"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Cursor="Hand"
                                               TextDecorations="Underline"
                                               MouseLeftButtonDown="OutlinerIdLink_Click"
                                               Visibility="{Binding IsShape, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text="]" Foreground="Gray" VerticalAlignment="Center" Visibility="{Binding IsShape, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="IsExpanded" Value="True" />
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="19" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition />
                                                </Grid.RowDefinitions>
                                                <ToggleButton x:Name="Expander"
                                                              ClickMode="Press"
                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                              Style="{StaticResource OutlinerExpandCollapseToggleStyle}" />
                                                <Border x:Name="Bd"
                                                        Grid.Column="1"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}"
                                                        SnapsToDevicePixels="true">
                                                    <ContentPresenter x:Name="PART_Header"
                                                                      ContentSource="Header"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost"
                                                                Grid.Row="1"
                                                                Grid.Column="1"
                                                                Grid.ColumnSpan="2" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="HasItems" Value="false">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                                </Trigger>
                                                <Trigger Property="IsExpanded" Value="false">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#37373D" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2D2E" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" 
                          Width="4" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch" 
                          Background="{StaticResource BorderBrush}" 
                          ResizeBehavior="PreviousAndNext" />

            <!-- Canvas, Timeline, and Console -->
            <Grid Grid.Column="2" x:Name="CanvasConsoleGrid">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="CanvasRow" Height="*" MinHeight="200" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="TimelineRow" Height="0" MinHeight="0" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="ConsoleRow" Height="200" MinHeight="80" />
                </Grid.RowDefinitions>

                <!-- Canvas -->
                <Border Grid.Row="0"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <canvas:RenderCanvas x:Name="RenderCanvas" />

                        <!-- Animation Controls Overlay -->
                        <Border x:Name="AnimationControlsPanel"
                                Visibility="Collapsed"
                                Background="#CC1E1E1E"
                                CornerRadius="8"
                                Padding="12,8"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="PlayPauseBtn" Content="▶"
                                        Style="{StaticResource MediaButtonStyle}"
                                        ToolTip="Play/Pause"
                                        Click="PlayPause_Click"/>
                                <Button x:Name="StopBtn" Content="■"
                                        Style="{StaticResource MediaButtonStyle}"
                                        ToolTip="Stop"
                                        Click="Stop_Click"/>
                                <TextBlock Text="Speed:" Foreground="White"
                                           VerticalAlignment="Center" Margin="12,0,4,0"/>
                                <Slider x:Name="SpeedSlider"
                                        Minimum="0.25" Maximum="4" Value="1"
                                        Width="80" VerticalAlignment="Center"
                                        ValueChanged="SpeedSlider_ValueChanged"/>
                                <TextBlock x:Name="SpeedText" Text="1x" Foreground="White"
                                           VerticalAlignment="Center" Margin="4,0,12,0" Width="30"/>
                                <TextBlock x:Name="TimeDisplay" Text="0.00s" Foreground="LightGray"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Splitter between Canvas and Timeline -->
                <GridSplitter x:Name="TimelineSplitter"
                              Grid.Row="1"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              ResizeBehavior="PreviousAndNext"
                              Background="{StaticResource BorderBrush}"
                              Cursor="SizeNS"
                              Visibility="Collapsed"
                              ToolTip="Drag to resize." />

                <!-- Timeline Panel -->
                <local:TimelinePanel Grid.Row="2" x:Name="TimelinePanel" Visibility="Collapsed" />

                <!-- Splitter between Timeline and Console -->
                <GridSplitter Grid.Row="3"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              ResizeBehavior="PreviousAndNext"
                              Background="{StaticResource BorderBrush}"
                              Cursor="SizeNS"
                              MouseDoubleClick="ConsoleSplitter_MouseDoubleClick"
                              ToolTip="Drag to resize. Double-click to reset." />

                <!-- Console Panel -->
                <Border Grid.Row="4"
                        Background="{StaticResource SecondaryBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Console Header -->
                        <Border Grid.Row="0"
                                Background="{StaticResource TertiaryBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,4">
                            <Grid>
                                <TextBlock Text="Console"
                                           Foreground="{StaticResource ForegroundBrush}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="ClearConsoleButton"
                                            Content="Clear"
                                            Style="{StaticResource RibbonButtonStyle}"
                                            Padding="8,4"
                                            Click="ClearConsoleButton_Click" />
                                    <Button x:Name="ExportConsoleButton"
                                            Content="Export"
                                            Style="{StaticResource RibbonButtonStyle}"
                                            Padding="8,4"
                                            Margin="4,0,0,0"
                                            Click="ExportConsoleButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Console Output -->
                        <ListBox Grid.Row="1"
                                 x:Name="ConsoleListBox"
                                 Background="{StaticResource BackgroundBrush}"
                                 BorderThickness="0"
                                 SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 KeyDown="ConsoleListBox_KeyDown"
                                 MouseDoubleClick="ConsoleListBox_MouseDoubleClick">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Copy" Click="ConsoleCopy_Click" InputGestureText="Ctrl+C">
                                        <MenuItem.Icon>
                                            <TextBlock Text="📋" FontSize="12"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="Select All" Click="ConsoleSelectAll_Click" InputGestureText="Ctrl+A"/>
                                    <Separator/>
                                    <MenuItem Header="Clear" Click="ClearConsoleButton_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3399FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- File:Line prefix for clickable errors -->
                                        <TextBlock FontFamily="Cascadia Code, Consolas, Courier New" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#808080" />
                                                    <Setter Property="Text" Value="{Binding ModuleName, StringFormat='[{0}:'}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsClickable}" Value="True">
                                                            <Setter Property="Foreground" Value="#4EC9B0" />
                                                            <Setter Property="Cursor" Value="Hand" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding LineNumber}"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#808080" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsClickable}" Value="True">
                                                            <Setter Property="Foreground" Value="#4EC9B0" />
                                                            <Setter Property="Cursor" Value="Hand" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="] "
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="12"
                                                   Foreground="#808080" />
                                        <!-- Message -->
                                        <TextBlock Text="{Binding Message}"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF5555" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Width="4"
                          Background="{StaticResource BorderBrush}"
                          Cursor="SizeWE" />

            <!-- Code Editor with Tabs -->
            <Border Grid.Column="4" Background="{StaticResource SecondaryBackgroundBrush}">
                <TabControl x:Name="MainTabControl" Background="{StaticResource SecondaryBackgroundBrush}" BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="{StaticResource TertiaryBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                            <Setter Property="Padding" Value="12,6" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1,1,1,0"
                                                CornerRadius="4,4,0,0"
                                                Margin="0,0,2,0"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter ContentSource="Header" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- Code Tab -->
                    <TabItem Header="Code">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- File Tabs -->
                            <!-- File Tabs -->
                            <ListBox x:Name="FileTabs"
                                     Grid.Row="0"
                                     Background="{StaticResource SecondaryBackgroundBrush}"
                                     BorderThickness="0"
                                     Padding="0"
                                     SelectionChanged="FileTabs_SelectionChanged">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="#969696" />
                                        <Setter Property="Padding" Value="10,6" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Grid Background="{TemplateBinding Background}">
                                                        <!-- Top Accent Border (Hidden by default) -->
                                                        <Border x:Name="AccentBorder"
                                                                VerticalAlignment="Top"
                                                                Height="2"
                                                                Background="{StaticResource AccentBrush}"
                                                                Visibility="Hidden" />
                                                        
                                                        <ContentPresenter Margin="{TemplateBinding Padding}" />
                                                        
                                                        <!-- Right separator -->
                                                        <Border HorizontalAlignment="Right" 
                                                                Width="1" 
                                                                Background="{StaticResource BorderBrush}" 
                                                                Opacity="0.5"
                                                                Margin="0,4" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2D2D2D" />
                                                            <Setter Property="Foreground" Value="#E0E0E0" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#1E1E1E" /> <!-- Match Editor Background -->
                                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                                            <Setter TargetName="AccentBorder" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- File Name -->
                                            <TextBlock Text="{Binding FileName}" 
                                                       VerticalAlignment="Center"
                                                       FontSize="13" />
                                            
                                            <!-- Unsaved Indicator -->
                                            <Ellipse Width="8" Height="8" 
                                                     Margin="6,1,0,0" 
                                                     Fill="{StaticResource ForegroundBrush}"
                                                     Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            
                                            <!-- Close Button -->
                                            <Button Click="CloseTab_Click"
                                                    Tag="{Binding}"
                                                    Margin="8,0,0,0"
                                                    Width="18" Height="18"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="BtnBorder" 
                                                                            Background="Transparent" 
                                                                            CornerRadius="2">
                                                                        <Path x:Name="IconPath"
                                                                              Data="M 0,0 L 8,8 M 0,8 L 8,0"
                                                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                              StrokeThickness="1.5"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"
                                                                              Width="8" Height="8" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#404040" />
                                                                            <Setter TargetName="IconPath" Property="Stroke" Value="White" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Active Editor -->
                            <Border Grid.Row="1" Background="#1E1E1E">
                                <avalonedit:TextEditor x:Name="CodeEditor"
                                                       FontFamily="Consolas"
                                                       FontSize="14"
                                                       ShowLineNumbers="True"
                                                       SyntaxHighlighting="C#"
                                                       Background="#1E1E1E"
                                                       Foreground="#D4D4D4"
                                                       LineNumbersForeground="#858585"
                                                       Padding="5"
                                                       VerticalScrollBarVisibility="Visible"
                                                       HorizontalScrollBarVisibility="Auto"
                                                       BorderThickness="0"
                                                       WordWrap="False" />
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- Settings Tab -->
                    <TabItem Header="Settings">
                        <Grid Background="{StaticResource BackgroundBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="24">

                                    <!-- PROJECT SETTINGS SECTION -->
                                    <Border Background="{StaticResource TertiaryBackgroundBrush}"
                                            CornerRadius="8"
                                            Padding="20"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            BorderThickness="2"
                                            Margin="0,0,0,24">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Project Settings"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                                <Border Background="#2D5A2D" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Saved per project" FontSize="11" Foreground="#90EE90"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="These values control the default appearance of new shapes. Leave them empty to use shape-specific defaults."
                                                       Foreground="Gray"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,16"
                                                       FontSize="12"/>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="300" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Stroke Color -->
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="Default Stroke Color:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,12"/>
                                                <TextBox x:Name="SettingsStrokeColorBox"
                                                         Grid.Row="0" Grid.Column="1"
                                                         Padding="6"
                                                         Margin="0,0,0,12"
                                                         Background="{StaticResource BackgroundBrush}"
                                                         Foreground="{StaticResource ForegroundBrush}"
                                                         BorderBrush="{StaticResource BorderBrush}"
                                                         TextChanged="ColorBox_TextChanged" />
                                                <Button x:Name="SettingsStrokeColorBtn"
                                                        Grid.Row="0" Grid.Column="2"
                                                        Click="PickColorButton_Click"
                                                        Tag="Stroke"
                                                        Content="..."
                                                        Background="#444444"
                                                        Foreground="White"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        Margin="8,0,0,12"
                                                        Width="30"
                                                        Height="30"
                                                        VerticalAlignment="Top"
                                                        ToolTip="Pick Stroke Color"/>

                                                <!-- Fill Color -->
                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="Default Fill Color:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,12"/>
                                                <TextBox x:Name="SettingsFillColorBox"
                                                         Grid.Row="1" Grid.Column="1"
                                                         Padding="6"
                                                         Margin="0,0,0,12"
                                                         Background="{StaticResource BackgroundBrush}"
                                                         Foreground="{StaticResource ForegroundBrush}"
                                                         BorderBrush="{StaticResource BorderBrush}"
                                                         TextChanged="ColorBox_TextChanged" />
                                                <Button x:Name="SettingsFillColorBtn"
                                                        Grid.Row="1" Grid.Column="2"
                                                        Click="PickColorButton_Click"
                                                        Tag="Fill"
                                                        Content="..."
                                                        Background="#444444"
                                                        Foreground="White"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        Margin="8,0,0,12"
                                                        Width="30"
                                                        Height="30"
                                                        VerticalAlignment="Top"
                                                        ToolTip="Pick Fill Color"/>

                                                <!-- Canvas Background -->
                                                <TextBlock Grid.Row="2" Grid.Column="0"
                                                           Text="Canvas Background:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,12"/>
                                                <TextBox x:Name="SettingsCanvasColorBox"
                                                         Grid.Row="2" Grid.Column="1"
                                                         Padding="6"
                                                         Margin="0,0,0,12"
                                                         Background="{StaticResource BackgroundBrush}"
                                                         Foreground="{StaticResource ForegroundBrush}"
                                                         BorderBrush="{StaticResource BorderBrush}"
                                                         TextChanged="ColorBox_TextChanged" />
                                                <Button x:Name="SettingsCanvasColorBtn"
                                                        Grid.Row="2" Grid.Column="2"
                                                        Click="PickColorButton_Click"
                                                        Tag="Canvas"
                                                        Content="..."
                                                        Background="#444444"
                                                        Foreground="White"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        Margin="8,0,0,12"
                                                        Width="30"
                                                        Height="30"
                                                        VerticalAlignment="Top"
                                                        ToolTip="Pick Canvas Background"/>

                                                <!-- Thickness -->
                                                <TextBlock Grid.Row="3" Grid.Column="0"
                                                           Text="Default Stroke Thickness:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,16"/>
                                                <TextBox x:Name="SettingsThicknessBox"
                                                         Grid.Row="3" Grid.Column="1"
                                                         Padding="6"
                                                         Margin="0,0,0,16"
                                                         Background="{StaticResource BackgroundBrush}"
                                                         Foreground="{StaticResource ForegroundBrush}"
                                                         BorderBrush="{StaticResource BorderBrush}" />

                                                <!-- Save Project Settings Button -->
                                                <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                                        Content="Save Project Settings"
                                                        Click="SaveSettingsButton_Click"
                                                        Style="{StaticResource RunButtonStyle}"
                                                        Padding="20,8"
                                                        HorizontalAlignment="Left"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- APPLICATION SETTINGS SECTION -->
                                    <Border Background="{StaticResource TertiaryBackgroundBrush}"
                                            CornerRadius="8"
                                            Padding="20"
                                            BorderBrush="#666666"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Application Settings"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="#CCCCCC"/>
                                                <Border Background="#4A3A2D" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Saved globally" FontSize="11" Foreground="#FFB347"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="These settings apply to all projects and are saved to your user profile."
                                                       Foreground="Gray"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,16"
                                                       FontSize="12"/>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="300" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Export Settings Sub-header -->
                                                <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                                                           Text="Export Settings"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           Margin="0,0,0,12"/>

                                                <!-- Export Background -->
                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="Default Export Background:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,12"/>
                                                <ComboBox x:Name="SettingsExportBackgroundCombo"
                                                          Grid.Row="1" Grid.Column="1"
                                                          Padding="6"
                                                          Margin="0,0,0,12"
                                                          Foreground="Black"
                                                          BorderBrush="{StaticResource BorderBrush}">
                                                    <ComboBox.ItemContainerStyle>
                                                        <Style TargetType="ComboBoxItem">
                                                            <Setter Property="Foreground" Value="Black"/>
                                                        </Style>
                                                    </ComboBox.ItemContainerStyle>
                                                    <ComboBoxItem Content="Transparent" />
                                                    <ComboBoxItem Content="Canvas Background" />
                                                    <ComboBoxItem Content="White" />
                                                    <ComboBoxItem Content="Black" />
                                                    <ComboBoxItem Content="Light (White Smoke)" />
                                                    <ComboBoxItem Content="Light" Visibility="Collapsed" />
                                                </ComboBox>

                                                <!-- Include Grid -->
                                                <TextBlock Grid.Row="2" Grid.Column="0"
                                                           Text="Include Grid in Export:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,16"/>
                                                <CheckBox x:Name="SettingsIncludeGridCheck"
                                                          Grid.Row="2" Grid.Column="1"
                                                          Content="Enabled"
                                                          Foreground="{StaticResource ForegroundBrush}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,0,16"/>

                                                <!-- Snap Settings Sub-header -->
                                                <TextBlock Grid.Row="3" Grid.ColumnSpan="3"
                                                           Text="Snap Settings (Ctrl+M to Measure)"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           Margin="0,8,0,12"/>

                                                <!-- Snap Endpoints -->
                                                <TextBlock Grid.Row="4" Grid.Column="0"
                                                           Text="Snap to Endpoints:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,8"/>
                                                <CheckBox x:Name="SnapEndpointCheck"
                                                          Grid.Row="4" Grid.Column="1"
                                                          Content="Enabled"
                                                          IsChecked="True"
                                                          Foreground="{StaticResource ForegroundBrush}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,0,8"/>

                                                <!-- Snap Midpoints -->
                                                <TextBlock Grid.Row="5" Grid.Column="0"
                                                           Text="Snap to Midpoints:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,8"/>
                                                <CheckBox x:Name="SnapMidpointCheck"
                                                          Grid.Row="5" Grid.Column="1"
                                                          Content="Enabled"
                                                          IsChecked="True"
                                                          Foreground="{StaticResource ForegroundBrush}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,0,8"/>

                                                <!-- Snap Centers -->
                                                <TextBlock Grid.Row="6" Grid.Column="0"
                                                           Text="Snap to Centers:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,8"/>
                                                <CheckBox x:Name="SnapCenterCheck"
                                                          Grid.Row="6" Grid.Column="1"
                                                          Content="Enabled"
                                                          IsChecked="True"
                                                          Foreground="{StaticResource ForegroundBrush}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,0,8"/>

                                                <!-- Snap Intersections -->
                                                <TextBlock Grid.Row="7" Grid.Column="0"
                                                           Text="Snap to Intersections:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,8"/>
                                                <CheckBox x:Name="SnapIntersectionCheck"
                                                          Grid.Row="7" Grid.Column="1"
                                                          Content="Enabled"
                                                          IsChecked="True"
                                                          Foreground="{StaticResource ForegroundBrush}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,0,8"/>

                                                <!-- Snap Nearest -->
                                                <TextBlock Grid.Row="8" Grid.Column="0"
                                                           Text="Snap to Nearest:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,8"/>
                                                <CheckBox x:Name="SnapNearestCheck"
                                                          Grid.Row="8" Grid.Column="1"
                                                          Content="Enabled"
                                                          IsChecked="True"
                                                          Foreground="{StaticResource ForegroundBrush}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,0,8"/>

                                                <!-- Snap Perpendicular -->
                                                <TextBlock Grid.Row="9" Grid.Column="0"
                                                           Text="Snap to Perpendicular:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,16"/>
                                                <CheckBox x:Name="SnapPerpendicularCheck"
                                                          Grid.Row="9" Grid.Column="1"
                                                          Content="Enabled"
                                                          IsChecked="True"
                                                          Foreground="{StaticResource ForegroundBrush}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,0,16"/>

                                                <!-- Highlight Settings Sub-header -->
                                                <TextBlock Grid.Row="10" Grid.ColumnSpan="3"
                                                           Text="Highlight Settings (Outliner Hover)"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           Margin="0,8,0,12"/>

                                                <!-- Highlight Color -->
                                                <TextBlock Grid.Row="11" Grid.Column="0"
                                                           Text="Highlight Color:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,8"/>
                                                <TextBox x:Name="HighlightColorBox"
                                                         Grid.Row="11" Grid.Column="1"
                                                         Padding="6"
                                                         Margin="0,0,0,8"
                                                         Background="{StaticResource BackgroundBrush}"
                                                         Foreground="{StaticResource ForegroundBrush}"
                                                         BorderBrush="{StaticResource BorderBrush}"
                                                         Text="Yellow"
                                                         TextChanged="HighlightColorBox_TextChanged"/>
                                                <Button x:Name="HighlightColorBtn"
                                                        Grid.Row="11" Grid.Column="2"
                                                        Click="PickHighlightColorButton_Click"
                                                        Width="30" Height="30"
                                                        Margin="8,0,0,8"
                                                        Background="Yellow"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        ToolTip="Pick Color"/>

                                                <!-- Highlight Opacity -->
                                                <TextBlock Grid.Row="12" Grid.Column="0"
                                                           Text="Highlight Opacity:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,16"/>
                                                <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,16">
                                                    <Slider x:Name="HighlightOpacitySlider"
                                                            Width="200"
                                                            Minimum="10"
                                                            Maximum="100"
                                                            Value="40"
                                                            VerticalAlignment="Center"
                                                            ValueChanged="HighlightOpacitySlider_ValueChanged"/>
                                                    <TextBlock x:Name="HighlightOpacityText"
                                                               Text="40%"
                                                               Foreground="{StaticResource ForegroundBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="10,0,0,0"
                                                               Width="40"/>
                                                </StackPanel>

                                                <!-- Canvas Settings Sub-header -->
                                                <TextBlock Grid.Row="13" Grid.ColumnSpan="3"
                                                           Text="Canvas Settings"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           Margin="0,8,0,12"/>

                                                <!-- Zoom to Fit on Run -->
                                                <TextBlock Grid.Row="14" Grid.Column="0"
                                                           Text="Zoom to Fit on Run:"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,0"/>
                                                <CheckBox x:Name="SettingsZoomToFitCheck"
                                                          Grid.Row="14" Grid.Column="1"
                                                          Content="Enabled"
                                                          Foreground="{StaticResource ForegroundBrush}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,0,0"
                                                          Checked="SettingsZoomToFitCheck_Changed"
                                                          Unchecked="SettingsZoomToFitCheck_Changed"/>
                                            </Grid>

                                            <!-- Note about auto-save -->
                                            <TextBlock Text="Application settings are saved automatically when changed."
                                                       Foreground="Gray"
                                                       FontSize="11"
                                                       FontStyle="Italic"
                                                       Margin="0,16,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Border>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="4"
                Background="{StaticResource SecondaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Foreground="{StaticResource ForegroundBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           Text="Ready" />

                <TextBlock x:Name="CoordinatesText"
                           Grid.Column="1"
                           Foreground="{StaticResource ForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="20,0"
                           FontFamily="Consolas"
                           Text="X: 0.00  Y: 0.00" />

                <TextBlock Grid.Column="2"
                           Foreground="{StaticResource ForegroundBrush}"
                           Opacity="0.6"
                           VerticalAlignment="Center"
                           Text="Scroll: Zoom | Middle-click: Pan" />
            </Grid>
        </Border>
    </Grid>
</Window>
